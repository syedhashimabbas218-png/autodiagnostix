# URL of the Strapi CMS API (used by Astro SSR to fetch products, categories, etc.)
# All Strapi API calls happen server-side — no browser code calls Strapi directly.
# - Same Coolify project with Docker network: use http://strapi:1337
# - Separate Coolify resources or external: use the public URL (e.g. https://cms.yourdomain.com)
PUBLIC_STRAPI_URL=http://localhost:1337

# Canonical site URL for sitemap generation and SEO meta tags
SITE_URL=https://autodiagnostix.com.pk
