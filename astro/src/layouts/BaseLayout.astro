---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  ogImageWidth?: string;
  ogImageHeight?: string;
  ogImageAlt?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  datePublished?: string;
  dateModified?: string;
  author?: string;
}

const SITE_NAME = 'Autodiagnostix';
const SITE_URL = import.meta.env.SITE_URL || 'https://autodiagnostix.com.pk';
const DEFAULT_OG_IMAGE = `${SITE_URL}/og-image.svg`;
const PUBLISHER_NAME = 'Autodiagnostix';

const {
  title,
  description = 'Pakistan\'s authorized dealer for LAUNCH, SMARTSAFE, UNITE, GTI.tools, Liberty Lifts and AUTOOL. Buy car lifts, 3D wheel aligners, ADAS, EV diagnostics, tyre changers and videoscopes. Delivery across Pakistan.',
  canonical,
  ogImage = DEFAULT_OG_IMAGE,
  ogType = 'website',
  ogImageWidth = '1200',
  ogImageHeight = '630',
  ogImageAlt = 'Autodiagnostix, Pakistan\'s authorized dealer for LAUNCH, Smartsafe, UNITE, GTI.tools, Liberty Lifts and AUTOOL',
  jsonLd,
  noindex,
  datePublished = '2024-01-01',
  dateModified = new Date().toISOString().slice(0, 10),
  author = PUBLISHER_NAME,
} = Astro.props;

// Don't append SITE_NAME if the title already ends with it (avoids "Foo | Bar | Bar" duplication).
const cleanTitle = (title || '').trim();
const siteNameLower = SITE_NAME.toLowerCase();
const cleanTitleLower = cleanTitle.toLowerCase();
const titleAlreadyHasSite = cleanTitleLower === siteNameLower || cleanTitleLower.endsWith(` | ${siteNameLower}`);
const fullTitle = title ? (titleAlreadyHasSite ? title : `${title} | ${SITE_NAME}`) : `Autodiagnostix | Launch, Smartsafe, UNITE Dealer in Pakistan`;
const ogUrl = canonical || SITE_URL;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="176x171" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@400;500;600;700;800&family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" /></noscript>

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={ogImageWidth} />
    <meta property="og:image:height" content={ogImageHeight} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_PK" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- E-E-A-T signals for AI/GEO -->
    <meta name="author" content={author} />
    <meta name="article:author" content={author} />
    <meta name="article:publisher" content={SITE_URL} />
    <meta name="article:published_time" content={datePublished} />
    <meta name="article:modified_time" content={dateModified} />
    <meta name="geo.region" content="PK-PB" />
    <meta name="geo.placename" content="Sahiwal, Pakistan" />
    <meta name="geo.position" content="30.6644;73.1085" />
    <meta name="ICBM" content="30.6644, 73.1085" />

    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    {jsonLd && (
      Array.isArray(jsonLd) ? jsonLd.map((ld, i) => (
        <script type="application/ld+json" set:html={JSON.stringify(ld)} />
      )) : (
        <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    )}

    <title>{fullTitle}</title>
  </head>
  <body class="bg-surface text-on-surface min-h-screen">
    <slot />
  </body>
</html>
