---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbListSchema, organizationSchema } from '../utils/schema';

export const prerender = false;

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Contact', url: 'https://autodiagnostix.com.pk/contact' },
];
---

<BaseLayout
  title="Contact Autodiagnostix, Workshop Equipment Quotes Across Pakistan"
  description="Get in touch with Autodiagnostix, Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE, Liberty Lifts, GTI.tools, and AUTOOL. Request a quote for car lifts, wheel aligners, diagnostic scanners, ADAS, EV diagnostic tools and workshop equipment. Delivery across Pakistan."
  canonical="https://autodiagnostix.com.pk/contact"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema()]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-surface pt-20 pb-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10" />
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-bl from-primary/8 via-transparent to-transparent" />
      <div class="relative max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-8" aria-label="Breadcrumb">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]" aria-hidden="true">/</span>
          <span class="text-primary font-bold" aria-current="page">Contact</span>
        </nav>
        <div class="max-w-3xl">
          <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            Get in <span class="text-primary">Touch</span>
          </h1>
          <p class="text-on-surface-variant text-xl md:text-2xl leading-relaxed max-w-2xl">
            Have a question about our products or need a personalized quote? Our team is ready to help.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    <section class="relative -mt-12 px-8 pb-20" aria-label="Contact information">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4" aria-hidden="true">location_on</span>
            <h2 class="font-headline font-bold text-lg text-on-surface mb-2">Address</h2>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Shalimar Town, Main Bypass Road<br />
              Sahiwal, Punjab<br />
              Pakistan
            </p>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4" aria-hidden="true">call</span>
            <h2 class="font-headline font-bold text-lg text-on-surface mb-2">Phone</h2>
            <a href="tel:+923227041953" class="block text-sm text-on-surface-variant hover:text-primary transition-colors">+92 322 7041953</a>
            <a href="tel:+923005399757" class="block text-sm text-on-surface-variant hover:text-primary transition-colors">+92 300 5399757</a>
            <a href="tel:+923055851888" class="block text-sm text-on-surface-variant hover:text-primary transition-colors">+92 305 5851888</a>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4" aria-hidden="true">mail</span>
            <h2 class="font-headline font-bold text-lg text-on-surface mb-2">Email</h2>
            <a href="mailto:info@autodiagnostix.com.pk" class="block text-sm text-on-surface-variant hover:text-primary transition-colors">info@autodiagnostix.com.pk</a>
            <a href="mailto:sales@autodiagnostix.com.pk" class="block text-sm text-on-surface-variant hover:text-primary transition-colors">sales@autodiagnostix.com.pk</a>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4" aria-hidden="true">schedule</span>
            <h2 class="font-headline font-bold text-lg text-on-surface mb-2">Business Hours</h2>
            <div class="space-y-1 text-sm text-on-surface-variant">
              <div class="flex justify-between"><span>Sat – Thu</span><span class="font-medium text-on-surface">9:00 – 18:00</span></div>
              <div class="flex justify-between"><span>Friday</span><span class="font-medium text-primary font-bold">Closed</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Form + Map -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
          <!-- Form -->
          <div class="lg:col-span-3">
            <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Send a Message</span>
            <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-8">
            Let's Start a Conversation
            </h2>
            <form action="/api/contact" method="POST" class="bg-surface-container-lowest rounded-xl p-8 md:p-10 shadow-sm border border-outline-variant/20">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mb-2">Full Name <span class="text-primary">*</span></label>
                  <input type="text" id="name" name="name" required
                    class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant/30 text-on-surface placeholder:text-on-surface-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                    placeholder="John Doe" />
                </div>
                <div>
                  <label for="email" class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mb-2">Email Address <span class="text-primary">*</span></label>
                  <input type="email" id="email" name="email" required
                    class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant/30 text-on-surface placeholder:text-on-surface-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                    placeholder="john@example.com" />
                </div>
                <div>
                  <label for="phone" class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mb-2">Phone Number</label>
                  <input type="tel" id="phone" name="phone"
                    class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant/30 text-on-surface placeholder:text-on-surface-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all"
                    placeholder="+92 322 7041953" />
                </div>
                <div>
                  <label for="subject" class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mb-2">Subject <span class="text-primary">*</span></label>
                  <select id="subject" name="subject" required
                    class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant/30 text-on-surface text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all">
                    <option value="" disabled selected>Select a topic</option>
                    <option value="general">General Inquiry</option>
                    <option value="quote">Request a Quote</option>
                    <option value="product">Product Information</option>
                    <option value="support">Technical Support</option>
                    <option value="parts">Spare Parts</option>
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
              <div class="mt-6">
                <label for="message" class="block text-xs font-label uppercase tracking-widest text-on-surface-variant font-bold mb-2">Message <span class="text-primary">*</span></label>
                <textarea id="message" name="message" required rows="5"
                  class="w-full px-4 py-3 bg-surface rounded-lg border border-outline-variant/30 text-on-surface placeholder:text-on-surface-variant/50 text-sm focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-all resize-none"
                  placeholder="Tell us about your requirements..."></textarea>
              </div>
              <div class="mt-2 text-xs text-on-surface-variant/60">Fields marked with <span class="text-primary">*</span> are required</div>
              <button type="submit"
                class="primary-gradient text-white font-headline font-bold text-xs uppercase tracking-widest px-10 py-4 rounded-lg hover:scale-[0.98] transition-all duration-200 cursor-pointer mt-6">
                Send Message
              </button>
            </form>
          </div>

          <!-- Map -->
          <div class="lg:col-span-2">
            <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Visit Us</span>
            <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-8">
              Our Location
            </h2>
            <a href="https://maps.app.goo.gl/CcdaixKZ7UpDFh9p9" target="_blank" rel="noopener noreferrer" class="block bg-surface-container-lowest rounded-xl overflow-hidden shadow-sm border border-outline-variant/20 hover:shadow-lg hover:border-primary/30 transition-all group">
              <div class="aspect-[4/3] bg-surface-container-high flex items-center justify-center text-on-surface-variant relative overflow-hidden">
                <div class="absolute inset-0 bg-[length:40px_40px] opacity-[0.03]" style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px);"></div>
                <div class="text-center p-8 relative z-10">
                  <span class="material-symbols-outlined text-5xl text-primary/40 mb-4 block" aria-hidden="true">map</span>
                  <p class="text-sm font-medium group-hover:text-primary transition-colors">Open in Google Maps</p>
                  <p class="text-xs mt-2 text-on-surface-variant/70">Shalimar Town, Main Bypass Road, Sahiwal</p>
                  <div class="mt-4 text-xs text-on-surface-variant/50 font-mono">30.6644° N / 73.1085° E</div>
                </div>
              </div>
            </a>
            <div class="mt-4 flex items-start gap-3 bg-primary/5 border border-primary/10 rounded-lg p-4">
              <span class="material-symbols-outlined text-primary text-sm mt-0.5" aria-hidden="true">info</span>
              <p class="text-xs text-on-surface-variant leading-relaxed">Prefer speaking with someone directly? Call our technical desk for immediate assistance during business hours.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative overflow-hidden py-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#a50a18] to-[#7d000b]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.12),transparent_50%)]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(255,255,255,0.06),transparent_40%)]" />
      <div class="relative max-w-3xl mx-auto text-center">
        <span class="text-xs font-label uppercase tracking-widest text-white/70 font-bold mb-4 block">Need Immediate Assistance?</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-white mb-6 leading-[1.08]">
          Call Our Technical Desk
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-lg mx-auto leading-relaxed">
          Our team is available during business hours to answer your questions and provide expert guidance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+923227041953"
            class="inline-flex items-center gap-2 bg-white text-primary font-extrabold px-10 py-4 text-sm uppercase tracking-widest rounded-lg hover:bg-white/90 hover:scale-[0.97] transition-all duration-200">
            <span class="material-symbols-outlined text-base" aria-hidden="true">call</span>
            +92 322 7041953
          </a>
          <a href="mailto:info@autodiagnostix.com.pk"
            class="inline-flex items-center gap-2 border border-white/40 text-white px-10 py-4 text-sm uppercase tracking-widest rounded-lg hover:bg-white/10 hover:scale-[0.97] transition-all duration-200">
            <span class="material-symbols-outlined text-base" aria-hidden="true">mail</span>
            Email Us
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .primary-gradient { background: linear-gradient(135deg, #97000d 0%, #bb2221 100%); }
</style>
