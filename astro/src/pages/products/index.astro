---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductGrid from '../../components/ProductGrid';
import { getProducts } from '../../lib/payload';
import { breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

let products: Awaited<ReturnType<typeof getProducts>> = [];
try {
  products = await getProducts();
} catch {
  // CMS offline — use empty set
}

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  { name: 'Products', url: 'https://autodiagnostix.com/products' },
];
---

<BaseLayout
  title="All Products"
  description="Browse our complete range of professional automotive diagnostic equipment, scanners, lifts, and workshop tools."
  canonical="https://autodiagnostix.com/products"
  jsonLd={breadcrumbListSchema(breadcrumbs)}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">All Products</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">All Products</h1>
        <p class="text-on-surface-variant text-xl max-w-xl">{products.length} products</p>
      </div>
    </header>

    <ProductGrid client:load products={products.map(p => ({
      id: p.id,
      name: p.name,
      brand: p.brand,
      badge: p.badge,
      image: p.heroImages?.[0] || '',
      description: p.summary?.substring(0, 120) || '',
    }))} />
  </main>

  <Footer />
</BaseLayout>
