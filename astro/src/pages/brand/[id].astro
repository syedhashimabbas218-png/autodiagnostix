---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getBrands } from '../../lib/strapi';
import { breadcrumbListSchema, brandSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
let brand = null;
let brandList: Awaited<ReturnType<typeof getBrands>> = [];
try {
  brandList = await getBrands();
  brand = brandList.find(b => b.slug === id) || null;
} catch { /* CMS offline */ }

if (!brand) return Astro.redirect('/404');

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  { name: 'Brands', url: 'https://autodiagnostix.com/brands' },
  { name: brand.name, url: `https://autodiagnostix.com/brand/${id}` },
];
---

<BaseLayout
  title={brand.name}
  description={`Browse ${brand.productCount} ${brand.name} products at Autodiagnostix.`}
  canonical={`https://autodiagnostix.com/brand/${id}`}
  jsonLd={[breadcrumbListSchema(breadcrumbs), brandSchema({ name: brand.name, url: `https://autodiagnostix.com/brand/${id}`, description: brand.description, image: brand.image })]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/brands" class="hover:text-primary transition-colors">Brands</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">{brand.name}</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">{brand.name}</h1>
        <p class="text-on-surface-variant text-xl max-w-xl">{brand.productCount} product{brand.productCount !== 1 ? 's' : ''} from {brand.name}</p>
      </div>
    </header>

    <section class="py-16 px-8 bg-surface-container-low text-center">
      <p class="text-on-surface-variant text-lg">Explore our complete range of {brand.name} products.</p>
      <a href="/products" class="inline-block mt-6 bg-primary text-white px-8 py-4 text-sm font-headline font-medium hover:brightness-110 transition-all">Browse All Products</a>
    </section>
  </main>

  <Footer />
</BaseLayout>
