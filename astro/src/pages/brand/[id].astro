---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBrands } from '../../lib/payload';
import { breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
const brands = await getBrands();
const brand = brands.find(b => b.slug === id);

if (!brand) {
  return Astro.redirect('/404');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  { name: 'Brands', url: 'https://autodiagnostix.com/brands' },
  { name: brand.name, url: `https://autodiagnostix.com/brand/${id}` },
];
---

<BaseLayout
  title={brand.name}
  description={`Browse ${brand.productCount} ${brand.name} products at Autodiagnostix.`}
  canonical={`https://autodiagnostix.com/brand/${id}`}
  jsonLd={breadcrumbListSchema(breadcrumbs)}
>
  <nav class="fixed top-0 w-full z-50 h-16 flex items-center bg-white/70 backdrop-blur-xl border-b border-white/20">
    <div class="flex justify-between items-center w-full px-8 max-w-screen-2xl mx-auto">
      <a href="/">
        <img src="/logo-full.png" alt="Autodiagnostix" class="h-14 w-auto object-contain" />
      </a>
      <a href="/contact" class="bg-primary text-white px-5 py-2 text-xs font-bold uppercase tracking-widest">
        Request a Quote
      </a>
    </div>
  </nav>

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/brands" class="hover:text-primary transition-colors">Brands</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">{brand.name}</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">{brand.name}</h1>
        <p class="text-on-surface-variant text-xl max-w-xl">{brand.productCount} product{brand.productCount !== 1 ? 's' : ''}</p>
      </div>
    </header>
  </main>
</BaseLayout>
