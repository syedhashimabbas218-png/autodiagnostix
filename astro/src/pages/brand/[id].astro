---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getBrands, getProducts, sortByAvailability } from '../../lib/strapi';
import { breadcrumbListSchema, brandSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
let brand: any = null;
let brandList: Awaited<ReturnType<typeof getBrands>> = [];
let brandProducts: any[] = [];

// Try to find the brand by both the URL slug and any legacy slug
// (e.g. "gtitools" for "GTI.tools"). The new Strapi brands use
// proper slugs (gti-tools), but getBrands() in strapi.ts still derives
// the old product-based slug. Match both.
function findBrand(list: Awaited<ReturnType<typeof getBrands>>, key: string) {
  const normalized = key.toLowerCase();
  return (
    list.find(b => b.slug === key) ||
    list.find(b => b.slug === normalized) ||
    list.find(b => b.name.toLowerCase().replace(/[^a-z0-9]+/g, '') === normalized.replace(/[^a-z0-9]+/g, '')) ||
    list.find(b => b.name.toLowerCase() === normalized)
  );
}

try {
  brandList = await getBrands();
  brand = findBrand(brandList, id || '');
  if (brand) {
    const all = sortByAvailability(await getProducts());
    // Match by any of the brand's name forms
    const brandName = brand.name.toLowerCase();
    const brandKey = brand.slug.toLowerCase().replace(/-/g, '');
    brandProducts = all.filter(p => p.brands.some(b => {
      const bn = b.toLowerCase();
      const bk = bn.replace(/[^a-z0-9]+/g, '');
      return bn === brandName || bk === brandKey;
    }));
  }
} catch { /* CMS offline */ }

if (!brand) return Astro.redirect('/404');

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Brands', url: 'https://autodiagnostix.com.pk/brands' },
  { name: brand.name, url: `https://autodiagnostix.com.pk/brand/${brand.slug}` },
];
---

<BaseLayout
  title={`${brand.name} Products in Pakistan , Authorized Dealer | Autodiagnostix`}
  description={`Browse ${brandProducts.length} ${brand.name} products in Pakistan at Autodiagnostix. Authorized ${brand.name} dealer for diagnostic scanners, car lifts, wheel aligners, tyre changers, ADAS, EV tools and workshop equipment. Delivery across Pakistan.`}
  canonical={`https://autodiagnostix.com.pk/brand/${brand.slug}`}
  jsonLd={[breadcrumbListSchema(breadcrumbs), brandSchema({ name: brand.name, url: `https://autodiagnostix.com.pk/brand/${brand.slug}`, description: brand.description, image: brand.image })]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/brands" class="hover:text-primary transition-colors">Brands</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">{brand.name}</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">{brand.name}</h1>
        <p class="text-on-surface-variant text-xl max-w-xl">{brandProducts.length} product{brandProducts.length !== 1 ? 's' : ''} from {brand.name}</p>
        {brand.description && <p class="text-on-surface-variant text-sm max-w-2xl mt-4 leading-relaxed">{brand.description}</p>}
      </div>
    </header>

    {brandProducts.length > 0 ? (
      <section class="py-16 px-8 bg-white">
        <div class="max-w-screen-2xl mx-auto">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {brandProducts.map(p => (
              <a href={`/product/${p.id}`} class="group relative bg-surface-container-low overflow-hidden hover:shadow-[0_0_0_1px_rgba(151,0,13,0.15)] transition-all duration-200 ease-out">
                <div class="aspect-[4/3] bg-white flex items-center justify-center overflow-hidden">
                  {p.heroImages && p.heroImages[0] ? (
                    <img src={p.heroImages[0]} alt={p.name} class="w-full h-full object-contain p-6 transition-transform duration-200 ease-out group-hover:scale-105" loading="lazy" referrerpolicy="no-referrer" />
                  ) : (
                    <div class="text-zinc-300 text-4xl">📦</div>
                  )}
                </div>
                <div class="p-5 bg-white">
                  <div class="flex items-center gap-2 mb-2">
                    {p.brands[0] && (
                      <span class="text-[9px] font-bold uppercase text-primary tracking-widest">{p.brands[0]}</span>
                    )}
                    <div class="h-px flex-1 bg-zinc-100"></div>
                  </div>
                  <h3 class="text-base font-headline font-extrabold mb-1 group-hover:text-primary transition-colors line-clamp-1">{p.name}</h3>
                  <p class="text-zinc-500 text-xs leading-relaxed line-clamp-2">{p.summary}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="py-16 px-8 bg-surface-container-low text-center">
        <p class="text-on-surface-variant text-lg">No products available right now. Explore our complete range of {brand.name} products on the main catalog.</p>
        <a href="/products" class="inline-block mt-6 bg-primary text-white px-8 py-4 text-sm font-headline font-medium hover:brightness-110 transition-all">Browse All Products</a>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>
