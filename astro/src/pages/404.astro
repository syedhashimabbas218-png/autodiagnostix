---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" noindex>
  <main class="min-h-screen flex flex-col items-center justify-center text-center px-8">
    <h1 class="font-headline text-9xl font-extrabold tracking-tighter text-[#97000d] mb-4">404</h1>
    <p class="text-2xl text-slate-500 mb-8">Page not found</p>
    <a href="/" class="bg-primary-gradient text-white px-8 py-4 text-sm font-headline font-medium hover:brightness-110 transition-all">
      Back to Home
    </a>
  </main>
</BaseLayout>
