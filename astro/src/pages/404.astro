---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';

export const prerender = true;

let popularProducts: { id: string; name: string; brand: string }[] = [];
try {
  const products = sortByAvailability(await getProducts());
  popularProducts = products.slice(0, 4).map(p => ({ id: p.id, name: p.name, brand: p.brand }));
} catch { /* CMS offline */ }

const popularLinks = [
  { name: 'Car Lifts in Pakistan', href: '/car-lifts-in-pakistan' },
  { name: 'Launch X431', href: '/launch-x431-pakistan' },
  { name: 'ADAS Calibration', href: '/adas-calibration-pakistan' },
  { name: 'Workshop Equipment', href: '/workshop-equipment-pakistan' },
  { name: 'Tyre Changers', href: '/tyre-changers-pakistan' },
  { name: 'EV Diagnostics', href: '/ev-diagnostics-pakistan' },
  { name: 'All Products', href: '/products' },
  { name: 'Contact Us', href: '/contact' },
];
---

<BaseLayout
  title="Page Not Found | Autodiagnostix"
  description="The page you are looking for could not be found. Browse our complete range of automotive diagnostic equipment, car lifts, and workshop tools."
  noindex
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20 bg-surface">
    <section class="py-20 px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="mb-6 flex justify-center">
          <img src="/logo-full.png" alt="Autodiagnostix" class="h-16 w-auto object-contain" width="200" height="64" />
        </div>
        <h1 class="font-headline text-8xl md:text-9xl font-extrabold tracking-tighter text-primary mb-4">404</h1>
        <p class="text-2xl text-on-surface mb-2 font-headline font-bold">Page not found</p>
        <p class="text-on-surface-variant text-lg mb-10 max-w-xl mx-auto">
          The page you are looking for does not exist or has been moved. Use the links below to find what you need, or head back to the homepage.
        </p>
        <a
          href="/"
          class="inline-block bg-primary text-white px-10 py-4 text-sm font-headline font-bold uppercase tracking-widest hover:brightness-110 transition-all"
        >
          ← Back to Home
        </a>
      </div>
    </section>

    <section class="py-16 px-8 bg-surface-container-low border-t border-outline-variant/10">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl font-headline font-extrabold tracking-tighter mb-8 text-center text-on-surface">Popular Pages</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {popularLinks.map(l => (
            <a
              href={l.href}
              class="block p-4 bg-surface-container-lowest border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all text-center"
            >
              <span class="text-sm font-headline font-bold text-on-surface group-hover:text-primary">{l.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {popularProducts.length > 0 && (
      <section class="py-16 px-8 bg-white border-t border-outline-variant/10">
        <div class="max-w-5xl mx-auto">
          <h2 class="text-2xl font-headline font-extrabold tracking-tighter mb-8 text-center text-on-surface">Featured Products</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {popularProducts.map(p => (
              <a
                href={`/product/${p.id}`}
                class="block p-4 bg-surface-container-lowest border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all"
              >
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">{p.brand}</p>
                <p class="text-sm font-headline font-bold text-on-surface leading-snug line-clamp-2">{p.name}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="py-12 px-8 bg-primary text-center text-white">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-headline font-extrabold mb-3">Need Help Finding Something?</h2>
        <p class="mb-6 text-white/80">Our team is available to help with quotes, product information, and orders across Pakistan.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact" class="inline-block bg-white text-primary px-8 py-3 text-sm font-headline font-bold uppercase tracking-widest hover:bg-zinc-100 transition-colors">
            Contact Us
          </a>
          <a href="/products" class="inline-block border border-white/40 text-white px-8 py-3 text-sm font-headline font-bold uppercase tracking-widest hover:bg-white/10 transition-colors">
            Browse All Products
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

