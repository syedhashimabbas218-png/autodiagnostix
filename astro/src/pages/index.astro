---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlideshow from '../components/HeroSlideshow';
import InteractiveLifts from '../components/InteractiveLifts';
import { organizationSchema, websiteSchema } from '../utils/schema';

export const prerender = true;

import heroData from '../data/hero-section.json';
import homeData from '../data/homepage-content.json';
const hero = heroData;
const home = homeData;

const seo = hero.seo;
const seoContent = home.seo;
const pageTitle = seo?.title || seoContent?.title;
const pageDesc = seo?.description || seoContent?.description;
---

<BaseLayout
  title={pageTitle || "Professional Automotive Diagnostics"}
  description={pageDesc || "Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE automotive diagnostic equipment."}
  canonical="https://autodiagnostix.com"
  jsonLd={[organizationSchema, websiteSchema]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main>
    <!-- HERO -->
    <HeroSlideshow client:load slides={hero.hero_slides} interval={heroData.slider_config.interval} />

    <!-- CATEGORY NAV -->
    <section id="category-nav" class="bg-white border-b border-zinc-100 py-10">
      <div class="max-w-[1536px] mx-auto px-8">
        <div class="flex overflow-x-auto no-scrollbar gap-12 justify-between">
          {(home.category_navigation?.categories || []).map(cat => (
            <a href={cat.href || `/category/${cat.id}`} class="flex flex-col items-center gap-4 min-w-[100px] group">
              <div class="w-12 h-12 rounded-full bg-surface-container-low flex items-center justify-center group-hover:bg-primary/10 transition-colors">
                <span class="material-symbols-outlined text-xl text-slate-600">{cat.icon || 'category'}</span>
              </div>
              <div class="text-center">
                <p class="font-headline font-bold text-sm tracking-tight text-on-surface group-hover:text-primary transition-colors">{cat.name}</p>
                <p class="text-[10px] text-slate-400 tracking-wider mt-0.5">{cat.product_count} products</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- NEW ARRIVALS -->
    {(home.new_arrivals?.products || []).length > 0 && (
      <section id="new-arrivals" class="py-24 bg-surface">
        <div class="max-w-[1536px] mx-auto px-8">
          <div class="flex items-end justify-between mb-16">
            <div>
              <span class="text-xs font-bold tracking-[0.2em] text-slate-500 mb-4 block uppercase">Precision Engineering</span>
              <h2 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter leading-[1.05] max-w-2xl">The New Standard in Hardware.</h2>
            </div>
            <a href="/products" class="hidden md:inline-flex text-sm font-label font-bold uppercase tracking-widest text-primary hover:underline underline-offset-4">View All &rarr;</a>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {(home.new_arrivals?.products || []).map(p => (
              <a href={`/product/${p.id}`} class="group bg-surface-container-lowest border border-zinc-100 hover:border-primary/20 p-8 flex flex-col transition-all hover:-translate-y-1 hover:shadow-2xl">
                {p.badge && (
                  <span class={`self-start mb-4 text-[9px] font-black uppercase tracking-widest px-3 py-1 ${p.badge.style === 'primary-bg-white-text' ? 'bg-primary text-white' : p.badge.style === 'secondary-bg' ? 'bg-zinc-100 text-zinc-800' : 'bg-zinc-50 text-zinc-600'} rounded-full`}>{p.badge.text}</span>
                )}
                <div class="aspect-[4/3] bg-white mb-6 flex items-center justify-center overflow-hidden">
                  <img src={p.image?.src} alt={p.image?.alt || p.name} class="w-full h-full object-contain group-hover:scale-105 transition-transform duration-700" loading="lazy" />
                </div>
                <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-1">{p.brand}</span>
                <h3 class="font-headline font-bold text-lg tracking-tight leading-snug mb-3 group-hover:text-primary transition-colors">{p.name}</h3>
                <p class="text-sm text-slate-500 leading-relaxed">{p.short_description}</p>
                <span class="text-sm font-bold mt-auto pt-6 text-primary tracking-tight">{p.price}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- STATS -->
    <section class="bg-surface-container-low py-24">
      <div class="max-w-[1536px] mx-auto px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-24">
          {(home.stats_section?.achievements || []).map(stat => (
            <div class="text-center">
              <div class="font-headline text-5xl md:text-6xl font-extrabold tracking-tighter mb-2 text-primary">{stat.value}</div>
              <p class="font-label text-sm font-bold tracking-wider">{stat.label}</p>
              <p class="text-xs text-slate-400 mt-1">{stat.description}</p>
            </div>
          ))}
        </div>
        <div class="text-center mb-16">
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-slate-400">Global Partnerships</span>
        </div>
        <div class="flex flex-wrap justify-center gap-16 items-center">
          {(home.stats_section?.partners?.brands || []).map(brand => (
            <div class="text-2xl font-headline font-extrabold tracking-tight text-slate-300 opacity-40 hover:opacity-100 transition-opacity grayscale hover:grayscale-0 cursor-default">{brand.name}</div>
          ))}
        </div>
      </div>
    </section>

    <!-- IMMERSIVE CATEGORIES -->
    {(home.immersive_categories?.sections || []).map(section => {
      const isEven = section.layout === 'content-right';
      return (
        <section id={section.id} class="relative h-[600px] flex items-center overflow-hidden bg-zinc-950">
          <img src={section.background?.image || ''} alt="" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-black/40"></div>
          <div class={`relative z-10 max-w-[1536px] mx-auto px-8 w-full ${isEven ? 'flex justify-end' : ''}`}>
            <div class={`backdrop-blur-md border border-white/20 p-16 max-w-[576px]`} style={{ backgroundColor: section.content_card?.bg || 'rgba(255,255,255,0.1)' }}>
              <h2 class="font-headline text-5xl font-extrabold tracking-tighter leading-[1.05] text-white mb-6">{section.title}</h2>
              <p class="text-zinc-300 text-lg leading-relaxed mb-8">{section.description}</p>
              <div class="flex flex-col gap-3 mb-10">
                {(section.highlights || []).map(h => (
                  <div class="flex items-center gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-primary"></div>
                    <span class="text-sm text-zinc-300"><strong class="text-white">{h.name}</strong> — {h.feature}</span>
                  </div>
                ))}
              </div>
              <a href={section.cta?.href || '/products'} class="inline-block bg-white text-zinc-900 px-8 py-4 font-headline font-medium text-sm hover:brightness-110 transition-all">
                {section.cta?.label || 'Explore'}
              </a>
            </div>
          </div>
        </section>
      );
    })}

    <!-- PROFESSIONAL EQUIPMENT -->
    <section id="professional-equipment" class="py-24 bg-white">
      <div class="max-w-[1536px] mx-auto px-8">
        <h2 class="font-headline text-5xl font-extrabold tracking-tighter mb-16">Heavy Duty Workshop Solutions</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {(home.professional_equipment?.categories || []).map(cat => (
            <div class="group">
              <div class="aspect-video bg-zinc-50 mb-8 overflow-hidden">
                <img src={cat.image} alt={cat.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" loading="lazy" />
              </div>
              <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-primary mb-4 block">{cat.tagline}</span>
              <h3 class="font-headline text-2xl font-extrabold tracking-tight mb-3">{cat.name}</h3>
              <p class="text-slate-500 text-sm leading-relaxed mb-6">{cat.description}</p>
              <div class="flex flex-wrap gap-2 mb-6">
                {(cat.features || []).map(f => <span class="text-[10px] font-label font-bold uppercase tracking-wider bg-zinc-100 px-3 py-1.5 rounded-full text-zinc-600">{f}</span>)}
              </div>
              <ul class="space-y-2">
                {(cat.products || []).map(p => (
                  <li class="text-sm text-slate-600 flex items-center gap-2"><span class="w-1 h-1 bg-primary rounded-full"></span>{p}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- LIFTS -->
    <InteractiveLifts
      client:load
      image={home.interactive_lifts?.image_section?.image || '/images/lift-2post.webp'}
      title={home.interactive_lifts?.content_section?.title || 'Hydraulic Precision. Absolute Safety.'}
      tagline={home.interactive_lifts?.content_section?.tagline || 'Product Focus'}
      liftTypes={home.interactive_lifts?.content_section?.lift_types || []}
    />

    <!-- CTA -->
    <section class="relative py-32 overflow-hidden" style="background: linear-gradient(135deg, #97000d 0%, #bb2221 100%);">
      <div class="max-w-[896px] mx-auto text-center relative z-10">
        <h2 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter leading-[1.05] text-white mb-6">Ready to elevate your diagnostic capabilities?</h2>
        <p class="text-zinc-200 text-lg leading-relaxed max-w-2xl mx-auto mb-12">Join Pakistan's leading service centers using Autodiagnostix professional equipment.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/contact" class="bg-white text-primary px-10 py-5 font-headline font-medium text-sm hover:brightness-95 transition-all">Get in Touch</a>
          <a href="/products" class="border border-white/40 text-white px-10 py-5 font-headline font-medium text-sm hover:bg-white/10 transition-all">Download Catalog</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('img').forEach(img => {
    img.addEventListener('load', function() {
      this.style.opacity = '1';
    });
    if (img.complete) img.style.opacity = '1';
  });
</script>

<style>
  img { opacity: 0; transition: opacity 0.3s; }
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  .primary-gradient { background: linear-gradient(135deg, #97000d 0%, #bb2221 100%); }
</style>
