---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSlideshow from '../components/HeroSlideshow';
import CategoryNav from '../components/CategoryNav';
import NewArrivals from '../components/NewArrivals';
import InteractiveLifts from '../components/InteractiveLifts';
import ClientsSection from '../components/ClientsSection.astro';
import { organizationSchema, websiteSchema, localBusinessSchema, faqSchema, speakableSchema, definitionBlock, articleSchema } from '../utils/schema';

const faqs = [
  {
    question: 'Where can I buy Launch X431 in Pakistan?',
    answer: 'Autodiagnostix is Pakistan\'s authorized dealer for Launch diagnostic tools, including the X431 PRO3 LINK, X431 PAD 9 LINK, X431 ADAS PRO PLUS, X431 CNC 605A, and the HD III heavy-duty module. We supply authentic products with warranty and after-sales support across Pakistan.',
  },
  {
    question: 'Do you supply car lifts and workshop equipment across Pakistan?',
    answer: 'Yes. We supply 2-post lifts, 4-post lifts, scissor lifts, wheel alignment lifts, and bulletproof vehicle lifts from Liberty Lifts and UNITE. We deliver to every city in Pakistan and provide installation guidelines with every order.',
  },
  {
    question: 'Do you offer ADAS calibration equipment in Pakistan?',
    answer: 'Yes. We supply the LAUNCH X-431 ADAS PRO PLUS and ADAS calibration tools from LAUNCH, with training and after-sales support. ADAS calibration is essential for workshops servicing modern vehicles with advanced driver-assistance systems.',
  },
  {
    question: 'What brands of wheel service equipment do you sell?',
    answer: 'We are the authorized dealer for GTI.tools in Pakistan, supplying precision tyre changers (G-Extreme, POWER X, RFT PRO) and automatic wheel balancers (LCD Premium with sonar). We also supply Launch 3D wheel aligners (WA613, X861 LITE, X861 PRO, U-VA2023) and Launch nitrogen tyre inflators.',
  },
  {
    question: 'Do you sell EV diagnostic equipment in Pakistan?',
    answer: 'Yes. We supply the LAUNCH EV Diagnosis Add-on Kit and the Launch EVM324 Battery Equalizer for EV service centers, plus UNITE EV workshop equipment.',
  },
  {
    question: 'What is the difference between Launch, Smartsafe, Unite, and AUTOOL?',
    answer: 'LAUNCH is the world\'s leading diagnostic brand for OBD2 scanners, ADAS, and EV tools. SMARTSAFE focuses on professional diagnostic and inspection tools. UNITE supplies workshop and tyre-service equipment like nitrogen inflators and lifts. AUTOOL specialises in affordable professional diagnostic and service tools. As Pakistan\'s authorized multi-brand dealer, we recommend the right tool for your workshop.',
  },
];

export const prerender = true;

import heroData from '../data/hero-section.json';
import homeData from '../data/homepage-content.json';
const hero = heroData;
const home = homeData;

const seo = hero.seo;
const seoContent = home.seo;
const pageTitle = seo?.title || seoContent?.title;
const pageDesc = seo?.description || seoContent?.description;

const icons: Record<string, string> = {
  share: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>`,
  mail: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  language: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  verified: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  support_agent: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>`,
  business: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
};

import { getProducts, getCategories, getBrands, sortByAvailability } from '../lib/strapi';

const STRAPI_URL = import.meta.env.PUBLIC_STRAPI_URL || 'http://localhost:1337';

const allCategories = await getCategories();
const categoryIcons: Record<string, string> = {
  'scanners': 'scanners',
  'lifts-jacks': 'lifts-jacks',
  'maintenance': 'maintenance',
  'wheel-alignment': 'wheel-alignment',
  'wheel-balancers': 'wheel-balancers',
  'tire-changers': 'tire-changers',
  'ev-equipment': 'ev-equipment',
};
const categories = allCategories
  .map(c => ({ id: c.id, name: c.name, icon: categoryIcons[c.id] || c.icon || 'build' }));

const allBrands = (await getBrands()).filter(b => b.slug !== 'gtitools');

// Fetch brand logos + descriptions from Strapi directly (getBrands in strapi.ts doesn't include logo)
const brandLogosRes = await fetch(`${STRAPI_URL}/api/brands?populate=*`);
const brandLogosJson: any = brandLogosRes.ok ? await brandLogosRes.json() : { data: [] };
const brandLogoMap: Record<string, string> = {};
const brandDescMap: Record<string, string> = {};
const strapiBrands: { slug: string; name: string }[] = [];
for (const b of (brandLogosJson.data || [])) {
  if (b.logo?.url) {
    const url = b.logo.url.startsWith('/') ? `${STRAPI_URL}${b.logo.url}` : b.logo.url;
    brandLogoMap[b.slug] = url;
  }
  if (b.description) brandDescMap[b.slug] = b.description;
  strapiBrands.push({ slug: b.slug, name: b.name });
}

// Merge: prefer Strapi's authoritative brand list (so newly-added brands
// like AUTOOL appear here even if no products reference them yet).
// Fall back to product-derived list for any brand without a Strapi entry.
const strapiList = strapiBrands.length > 0
  ? strapiBrands
  : (allBrands || []).map(b => ({ slug: b.slug, name: b.name }));

// Force the display order: Launch, Smartsafe, Unite, Liberty Lifts, GTI.tools, Autool
const ORDER = ['launch', 'smartsafe', 'unite', 'liberty-lifts', 'gti-tools', 'autool'];
const mergedBrands = ORDER
  .map(slug => strapiList.find(b => b.slug === slug))
  .filter((b): b is { slug: string; name: string } => Boolean(b));

const allProducts = sortByAvailability(await getProducts());
const NEW_ARRIVAL_IDS = ['919-max', 'wa613-wireless-3d-wheel-aligner', 'launch-evm324'];
const products = allProducts
  .filter(p => NEW_ARRIVAL_IDS.includes(p.id))
  .sort((a, b) => NEW_ARRIVAL_IDS.indexOf(a.id) - NEW_ARRIVAL_IDS.indexOf(b.id))
  .map(p => ({
    id: p.id,
    name: p.name,
    summary: p.summary || '',
    description: p.description || '',
    heroImages: p.heroImages,
  }));
---

<BaseLayout
  title={pageTitle || "Autodiagnostix"}
  description={pageDesc || "Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE, GTI.tools, Liberty Lifts & AUTOOL. Buy car lifts, wheel aligners, ADAS calibration tools, EV diagnostics, tyre changers, wheel balancers, and videoscopes. Delivery across Pakistan."}
  canonical="https://autodiagnostix.com.pk"
  ogType="website"
  jsonLd={[
    organizationSchema,
    websiteSchema,
    localBusinessSchema(),
    faqSchema(faqs),
    speakableSchema('https://autodiagnostix.com.pk/', ['h1', '.geo-answer', 'summary']),
    definitionBlock(
      'Autodiagnostix',
      "Autodiagnostix is Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE, GTI.tools, Liberty Lifts, and AUTOOL automotive diagnostic and workshop equipment, headquartered in Sahiwal, Punjab, and delivering across Pakistan.",
      'https://autodiagnostix.com.pk/about'
    ),
    articleSchema({
      headline: 'Autodiagnostix: Pakistan\'s Authorized Dealer for LAUNCH, Smartsafe, UNITE, GTI.tools, Liberty Lifts & AUTOOL',
      description: 'Pakistan\'s authorized dealer for LAUNCH, SMARTSAFE, UNITE, GTI.tools, Liberty Lifts and AUTOOL. Car lifts, 3D wheel aligners, ADAS, EV diagnostics, tyre changers, wheel balancers, battery testers, videoscopes.',
      url: 'https://autodiagnostix.com.pk/',
      keywords: ['Launch X431 Pakistan', 'car lifts Pakistan', '3D wheel alignment Pakistan', 'ADAS calibration Pakistan', 'EV diagnostics Pakistan', 'GTI.tools Pakistan', 'Liberty Lifts Pakistan', 'workshop equipment Pakistan'],
    }),
  ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" transparentOnScroll={true} />

  <main>
    <!-- HERO -->
    <HeroSlideshow client:load slides={hero.hero_slides} interval={heroData.slider_config.interval} />

    <!-- SEO HEADLINE BLOCK -->
    <section class="bg-white pt-20 pb-10 px-4 md:px-8 border-b border-zinc-100">
      <div class="max-w-screen-2xl mx-auto">
        <h1 class="text-fluid-4 font-headline font-extrabold tracking-tighter text-on-surface max-w-5xl leading-[1.1] mb-6">
          Pakistan's Authorized Dealer for <span class="text-primary">Launch, Smartsafe, Unite, GTI.tools, Liberty Lifts &amp; AUTOOL</span>
        </h1>
        <p class="geo-quotable text-on-surface-variant text-fluid-2 max-w-4xl leading-relaxed">
          Autodiagnostix supplies professional automotive diagnostic scanners, <strong>car lifts</strong>, <strong>2-post &amp; 4-post lifts</strong>, <strong>scissor lifts</strong>, <strong>3D wheel alignment</strong>, <strong>tyre changers</strong>, <strong>wheel balancers</strong>, <strong>ADAS calibration</strong>, <strong>EV diagnostics</strong>, <strong>battery testers</strong> and <strong>videoscopes</strong> to workshops, dealerships and service centers across Pakistan. With delivery and installation guidelines available for every city.
        </p>


      </div>
    </section>

    <!-- CATEGORY NAV -->
    <CategoryNav client:load categories={categories} />

    <!-- NEW ARRIVALS -->
    <NewArrivals client:load products={products} />

    <!-- STATS + PARTNERS + CERTIFICATIONS -->
    <section id="stats" class="py-20 overflow-hidden relative bg-[#FAFAFA] text-zinc-900">
      <div class="max-w-screen-2xl mx-auto px-8 relative z-10">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-12 border-t border-black/10 pt-16">
          {(home.stats_section?.achievements || []).map(stat => (
            <div>
              <div class={`text-5xl font-headline font-extrabold mb-2 ${stat.style === 'primary-accent' ? 'text-primary' : ''}`}>
                {stat.value}
              </div>
              <div class="text-[10px] uppercase tracking-widest text-zinc-500">{stat.label}</div>
            </div>
          ))}
        </div>

        <div class="mt-24 mb-20">
          <div class="flex items-center gap-4 mb-12">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">{home.stats_section?.partners?.section_title || 'Global Partnerships'}</span>
            <div class="h-px flex-1 bg-black/[0.08]"></div>
          </div>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6 md:gap-10 items-center">
            {mergedBrands.map(brand => {
              const logoSrc = brandLogoMap[brand.slug] || '';
              return (
                <a
                  href={`/brand/${brand.slug}`}
                  class="group flex flex-col items-center justify-center gap-2 px-4 py-6 border border-transparent hover:border-zinc-200 transition-all duration-200 ease-out"
                  title={brand.name}
                  aria-label={brand.name}
                >
                  {logoSrc ? (
                    <img
                      src={logoSrc}
                      alt={brand.name}
                      class="brand-logo w-[100px] h-auto max-w-full max-h-16 object-contain transition-all duration-200 ease-out"
                      loading="lazy"
                      referrerpolicy="no-referrer"
                    />
                  ) : (
                    <span class="brand-logo-fallback text-xl font-black tracking-tighter text-zinc-900 transition-colors duration-200 ease-out">
                      {brand.name}
                    </span>
                  )}
                </a>
              );
            })}
          </div>
        </div>

        <div class="mt-24 border-t border-black/[0.08] pt-20">
          <div class="flex flex-col md:flex-row justify-between items-start gap-12">
            <div class="max-w-xs">
              <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary mb-4 block">{home.stats_section?.certifications?.section_subtitle || 'Industry Excellence'}</span>
              <h2 class="text-3xl font-headline font-extrabold tracking-tighter text-zinc-900">{home.stats_section?.certifications?.section_title || 'Recognition & Awards'}.</h2>
              <p class="mt-4 text-zinc-500 text-sm leading-relaxed">{home.stats_section?.certifications?.description || ''}</p>
            </div>
            <div class="flex-1 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 w-full">
              {(home.stats_section?.certifications?.items || []).map(cert => (
                <div class="p-6 bg-white border border-black/[0.08] hover:border-primary/20 transition-colors">
                  <span class="text-primary mb-4 block w-6 h-6" set:html={icons[cert.icon] || ''}></span>
                  <h4 class="text-sm font-headline font-bold text-zinc-900 mb-1">{cert.name}</h4>
                  <p class="text-xs text-zinc-500">{cert.description}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CLIENTS -->
    <ClientsSection />

    <!-- IMMERSIVE CATEGORIES -->
    <section id="immersive-categories" class="py-12 bg-surface">
      <div class="max-w-screen-2xl mx-auto px-8 space-y-8">
        {(home.immersive_categories?.sections || []).map(section => {
          const isRight = section.layout === 'content-right';
          return (
            <div class={`relative min-h-[320px] md:min-h-[500px] bg-zinc-100 overflow-hidden flex items-center ${isRight ? 'md:justify-end' : ''}`}>
              <div class="absolute inset-0">
                <img src={section.background?.image || ''} alt={section.background?.alt || section.title} class="w-full h-full object-cover object-center" loading="lazy" referrerpolicy="no-referrer" width="800" height="600" />
              </div>
              <div class={`relative z-10 p-6 md:p-16 max-w-xl ${isRight ? 'bg-zinc-950/80 backdrop-blur-md md:mr-16' : 'bg-white/10 backdrop-blur-md border border-white/20 md:ml-16'}`}>
                <h2 class="text-2xl md:text-4xl font-headline font-extrabold text-white mb-4 md:mb-6">{section.title}</h2>
                <p class={`mb-6 md:mb-8 leading-relaxed text-sm md:text-base ${isRight ? 'text-zinc-400' : 'text-white/80'}`}>{section.description}</p>
                <button
                  onClick={() => { window.location.href = section.cta?.href || '/products'; }}
                  class={`px-6 md:px-8 py-3 font-headline font-medium text-[10px] md:text-xs uppercase tracking-widest transition-all cursor-pointer whitespace-nowrap ${
                    isRight
                      ? 'primary-gradient text-white hover:scale-[0.98]'
                      : 'bg-white text-zinc-900 hover:bg-zinc-100'
                  }`}
                >
                  {section.cta?.label || 'Explore'}
                </button>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- PROFESSIONAL EQUIPMENT -->
    <section id="professional-equipment" class="py-24 bg-white px-8">
      <div class="max-w-screen-2xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-12">{home.professional_equipment?.title || 'Heavy Duty Workshop Solutions'}</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
          {(home.professional_equipment?.categories || []).map((cat, idx) => (
            <div onclick="window.location.href='/products'" class="group cursor-pointer hover:-translate-y-1 hover:scale-[1.02] transition-all duration-200 ease-out">
              <div class="aspect-video bg-surface-container-low mb-6 overflow-hidden">
                <img src={cat.image} alt={cat.name} class="w-full h-full object-cover transition-transform duration-200 ease-out group-hover:scale-110" loading="lazy" referrerpolicy="no-referrer" width="800" height="600" />
              </div>
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-bold uppercase text-primary tracking-widest">{cat.tagline}</span>
                <div class="h-px flex-1 bg-zinc-100"></div>
              </div>
              <h3 class="text-xl font-headline font-extrabold mb-3 group-hover:text-primary transition-colors">{cat.name}</h3>
              <p class="text-zinc-500 text-sm leading-relaxed mb-6">{cat.description}</p>
            </div>
          ))}
        </div>

        <div class="mt-16 pt-12 border-t border-zinc-100">
          <div class="flex items-center gap-4 mb-8">
            <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Featured Heavy-Duty Equipment</span>
            <div class="h-px flex-1 bg-zinc-100"></div>
            <a href="/products" class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 hover:text-primary transition-colors">View All →</a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {allProducts
              .filter(p => ['liberty-tpf-15c', 'gti-g-extreme', 'gti-lcd-premium'].includes(p.id))
              .map(p => (
                <a href={`/product/${p.id}`} class="group relative bg-surface-container-low overflow-hidden hover:shadow-[0_0_0_1px_rgba(151,0,13,0.15)] transition-all duration-200 ease-out">
                  <div class="aspect-[4/3] bg-white flex items-center justify-center overflow-hidden">
                    {p.heroImages && p.heroImages[0] ? (
                      <img src={p.heroImages[0]} alt={p.name} class="w-full h-full object-contain p-6 transition-transform duration-200 ease-out group-hover:scale-105" loading="lazy" referrerpolicy="no-referrer" width="800" height="600" />
                    ) : (
                      <div class="text-zinc-300 text-4xl">📦</div>
                    )}
                  </div>
                  <div class="p-5 bg-white">
                    <div class="flex items-center gap-2 mb-2">
                      {p.brands && p.brands[0] && (
                        <span class="text-[9px] font-bold uppercase text-primary tracking-widest">{p.brands[0]}</span>
                      )}
                      <div class="h-px flex-1 bg-zinc-100"></div>
                    </div>
                    <h3 class="text-base font-headline font-extrabold mb-1 group-hover:text-primary transition-colors line-clamp-1">{p.name}</h3>
                    <p class="text-zinc-500 text-xs leading-relaxed line-clamp-2">{p.summary}</p>
                  </div>
                </a>
              ))}
          </div>
        </div>
      </div>
    </section>

    <!-- LIFTS -->
    <InteractiveLifts
      client:load
      image="/images/2postlift.jpeg"
      title={home.interactive_lifts?.content_section?.title || 'Hydraulic Precision. Absolute Safety.'}
      tagline={home.interactive_lifts?.content_section?.tagline || 'Product Focus'}
      liftTypes={home.interactive_lifts?.content_section?.lift_types || []}
    />

    <!-- SEO PRODUCT CLUSTERS (keyword-dense internal links) -->
    <section class="py-24 px-8 bg-surface-container-low">
      <div class="max-w-screen-2xl mx-auto">
        <div class="flex items-center gap-4 mb-12">
          <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary">Explore Our Range</span>
          <div class="h-px flex-1 bg-black/[0.08]"></div>
        </div>
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-10 text-on-surface">Professional Workshop Equipment &amp; Diagnostic Tools in Pakistan</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          <a href="/car-lifts-in-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">Car Lifts in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">2-post, 4-post and scissor car lifts from Liberty Lifts and UNITE. Heavy-duty and bulletproof vehicle lifts.</p>
          </a>
          <a href="/wheel-alignment-in-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">3D Wheel Alignment in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">Launch X861 PRO, X861 LITE, U-VA2023 wireless 3D wheel aligners for modern workshops.</p>
          </a>
          <a href="/tyre-changers-in-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">Tyre Changers in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">GTI.tools G-Extreme, POWER X and RFT PRO tyre changers with low-profile and run-flat capability.</p>
          </a>
          <a href="/wheel-balancers-in-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">Wheel Balancers in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">GTI.tools LCD Premium automatic wheel balancer with sonar system, plus Launch balancers.</p>
          </a>
          <a href="/launch-x431-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">Launch X431 in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">Authorized dealer for Launch X431 PRO3 LINK, PAD 9 LINK, CNC 605A, ADAS PRO PLUS, EV toolkit & more.</p>
          </a>
          <a href="/adas-calibration-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">ADAS Calibration in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">Launch X-431 ADAS PRO PLUS , dealer-level ADAS calibration for camera, radar and lidar.</p>
          </a>
          <a href="/ev-diagnostics-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">EV Car Diagnostics in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">Launch EV Diagnosis Add-on Kit, EVM324 battery equalizer , purpose-built for EV service centers.</p>
          </a>
          <a href="/battery-testers-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
            <h3 class="font-headline font-extrabold text-xl mb-2 group-hover:text-primary">Battery Testers in Pakistan</h3>
            <p class="text-sm text-zinc-500 leading-relaxed">BST-560 / BST-860 professional battery testers from Smartsafe. Plus plug testers, SPT360 spark plug tester.</p>
          </a>
          <a href="/videoscope-pakistan" class="group bg-white p-8 border border-zinc-100 hover:border-primary/30 hover:shadow-lg transition-all">
