---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const alignmentLifts = allProducts.filter(p => /ismarttlt|fr-?6108|pl-fs|4-post|four-post|wa613|x861/i.test(p.name + ' ' + p.summary));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Alignment Lifts in Pakistan', url: 'https://autodiagnostix.com.pk/alignment-lifts-pakistan' },
];

const faqs = [
  { question: 'What is an alignment lift?', answer: 'An alignment lift is a 4-post lift or scissor lift with integrated turnplates, slip plates, and jacking beams , purpose-built for 3D wheel alignment. Unlike a standard 2-post lift, an alignment lift provides a level, stable platform and unobstructed access to all four wheels for accurate alignment measurements.' },
  { question: 'Which alignment lift is best in Pakistan?', answer: 'For high-volume alignment, the UNITE PL-FS40 4-post lift is the most popular. For lower ceilings, the Liberty FR-6108 alignment scissor lift is ideal. The Launch iSmartTLT 242 is a smart alignment scissor for mid-range workshops.' },
];
---

<BaseLayout
  title="Buy Alignment Lifts in Pakistan | 4-Post &amp; Scissor"
  description="Buy wheel alignment lifts in Pakistan from Autodiagnostix. 4-post &amp; scissor alignment lifts with turnplates. UNITE PL-FS40, Liberty FR-6108, Launch iSmartTLT 242. Purpose-built for 3D wheel alignment. Delivery nationwide."
  canonical="https://autodiagnostix.com.pk/alignment-lifts-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Alignment Lifts in Pakistan: 4-Post & Scissor',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Alignment Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/alignment-lifts-pakistan',
      keywords: ['alignment lift Pakistan', 'wheel alignment lift Pakistan', '4-post alignment lift Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/alignment-lifts-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Alignment Lifts',
        'Alignment lifts are 4-post or scissor lifts with integrated turnplates, slip plates, and jacking beams for 3D wheel alignment. Purpose-built for alignment workshops, providing a level platform and unobstructed access to all four wheels.',
        'https://autodiagnostix.com.pk/alignment-lifts-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Alignment Lifts</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Alignment Lifts in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>alignment lifts in Pakistan</strong>. We supply 4-post and scissor alignment lifts with integrated turnplates, slip plates, and jacking beams , purpose-built for <a href="/wheel-alignment-in-pakistan" class="text-primary hover:underline">3D wheel alignment</a>. UNITE PL-FS40, Liberty FR-6108, Launch iSmartTLT 242, and more.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Alignment Lift Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {alignmentLifts.length > 0 ? alignmentLifts.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , alignment lift in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Alignment Lift · {p.brand || 'Workshop'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse <a href="/4-post-car-lifts-pakistan" class="text-primary underline">4-post lifts</a> or <a href="/scissor-lifts-pakistan" class="text-primary underline">scissor lifts</a>.</p>
          )}
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Alignment Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      details[open] .geo-answer,

      details[open] > p:last-of-type {

        animation: faqFadeIn 0.2s ease-out;

      }

      @keyframes faqFadeIn {

        from { opacity: 0; transform: translateY(-6px); }

        to { opacity: 1; transform: translateY(0); }

      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get an Alignment Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your alignment bay size and ceiling height , we'll recommend the right alignment lift.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
