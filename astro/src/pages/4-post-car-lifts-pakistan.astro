---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const fourPost = allProducts.filter(p => /four-post|4-post|pl-fs|pl-/i.test(p.name));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Car Lifts', url: 'https://autodiagnostix.com.pk/car-lifts-in-pakistan' },
  { name: '4-Post Lifts', url: 'https://autodiagnostix.com.pk/4-post-car-lifts-pakistan' },
];

const faqs = [
  { question: 'What is a 4-post car lift used for?', answer: 'A 4-post car lift is primarily used for wheel alignment, storage, inspection bays, and lifting long-wheelbase vehicles. 4-post lifts in Pakistan are commonly paired with 3D wheel aligners and are ideal for dealerships and high-volume workshops.' },
  { question: 'How much does a 4-post lift cost in Pakistan?', answer: '4-post car lifts in Pakistan range from PKR 800,000 to PKR 2,500,000 depending on capacity (4 to 6 tons) and features. The UNITE PL-FS40 is a popular 4-ton 4-post lift for wheel alignment workshops.' },
  { question: 'Do 4-post lifts work for wheel alignment?', answer: 'Yes , 4-post lifts with sliding/turning plates and rear slip plates are the standard for 3D wheel alignment in Pakistan. The UNITE PL-FS40 supports wheel alignment jacking beams for both 2D and 3D aligners.' },
];
---

<BaseLayout
  title="Buy 4-Post Car Lifts in Pakistan | UNITE PL-FS40"
  description="Buy 4-post car lifts in Pakistan from Autodiagnostix. Authorized UNITE dealer. 4 to 6 ton capacities for wheel alignment &amp; storage. Prices from PKR 800,000. Delivery &amp; installation Karachi, Lahore, Islamabad &amp; all Pakistan."
  canonical="https://autodiagnostix.com.pk/4-post-car-lifts-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: '4-Post Car Lifts in Pakistan: UNITE Dealer',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for 4-Post Car Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/4-post-car-lifts-pakistan',
      keywords: ['4-post car lifts Pakistan', 'wheel alignment lift Pakistan', 'UNITE Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/4-post-car-lifts-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        '4-Post Car Lifts',
        '4-post car lifts are heavy-duty workshop lifts with four posts for stability, used for wheel alignment, vehicle storage, and servicing long-wheelbase vehicles. Capacities from 4 to 6 tons. Standard for alignment workshops and dealerships in Pakistan.',
        'https://autodiagnostix.com.pk/4-post-car-lifts-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/car-lifts-in-pakistan" class="hover:text-primary transition-colors">Car Lifts</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">4-Post Lifts</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          4-Post Car Lifts in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>4-post car lifts in Pakistan</strong>. UNITE 4-post lifts with 4 to 6-ton capacities , purpose-built for <a href="/wheel-alignment-in-pakistan" class="text-primary hover:underline">3D wheel alignment</a>, storage, and long-wheelbase vehicles. Delivery and installation across Pakistan.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">4-Post Lift Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {fourPost.length > 0 ? fourPost.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , 4-post car lift in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">4-Post Lift · {p.brand || 'UNITE'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse our <a href="/car-lifts-in-pakistan" class="text-primary underline">car lift catalog</a> for 4-post options.</p>
          )}
        </div>
      </div>
    </section>

    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">4-Post Lifts for Wheel Alignment & Storage</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <p>A <strong>4-post car lift</strong> is the standard choice for <strong>3D wheel alignment in Pakistan</strong>. The four columns and runways provide a stable, level platform , much more accurate than a scissor lift for alignment work. Most Pakistani alignment workshops pair a 4-post lift with a Launch 3D wheel aligner such as the <strong>WA613</strong>, <strong>X861 LITE</strong>, <strong>X861 PRO</strong>, or <strong>UNITE U-VA2023</strong>.</p>
          <p class="mt-4">We also supply 4-post lifts for vehicle storage (parking stackers), inspection bays, and heavy-vehicle service. The <strong>UNITE PL-FS40</strong> is a 4-ton 4-post lift with hydraulic jack beam, sliding turnplates and rear slip plates , fully equipped for high-volume alignment work.</p>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About 4-Post Car Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a 4-Post Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your alignment needs and workshop dimensions , we'll recommend the right 4-post lift with delivery and installation.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
