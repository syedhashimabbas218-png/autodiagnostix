---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const twoPost = allProducts.filter(p => /two-post|2-post|tpf/i.test(p.name));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Car Lifts', url: 'https://autodiagnostix.com.pk/car-lifts-in-pakistan' },
  { name: '2-Post Lifts', url: 'https://autodiagnostix.com.pk/2-post-car-lifts-pakistan' },
];

const faqs = [
  { question: 'What is the price of a 2-post car lift in Pakistan?', answer: 'A 2-post car lift in Pakistan costs between PKR 450,000 and PKR 1,200,000 depending on capacity (3.5T to 6.8T) and brand. Liberty Lifts 2-post lifts start at 3.5 tons and go up to 6.8 tons for heavy-duty SUVs and commercial vehicles.' },
  { question: 'Which 2-post lift is best for SUVs in Pakistan?', answer: 'For SUVs in Pakistan, choose a 4-ton or higher 2-post lift with asymmetric arms and adequate ceiling height. The Liberty TPF-15C 6.8-ton two-post lift is ideal for Toyota Land Cruiser, Prado, and other heavy SUVs.' },
  { question: 'Do 2-post lifts need a special foundation?', answer: 'Yes. 2-post lifts must be installed on a concrete floor of minimum 150mm (6 inch) thickness with 3000 PSI compressive strength. We provide foundation specifications with every quote and offer installation services across Pakistan.' },
];
---

<BaseLayout
  title="Buy 2-Post Car Lifts in Pakistan | Liberty &amp; UNITE"
  description="Buy 2-post car lifts in Pakistan from Autodiagnostix. Prices PKR 450,000–1,200,000. Authorized dealer for Liberty Lifts &amp; UNITE. 3.5T to 6.8T capacities. Delivery &amp; installation Karachi, Lahore, Islamabad &amp; all Pakistan."
  canonical="https://autodiagnostix.com.pk/2-post-car-lifts-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: '2-Post Car Lifts in Pakistan: Liberty Lifts Dealer',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for 2-Post Car Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/2-post-car-lifts-pakistan',
      keywords: ['2-post car lifts Pakistan', 'car lifts Pakistan', 'Liberty Lifts Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/2-post-car-lifts-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        '2-Post Car Lifts',
        '2-post car lifts (also called two-post lifts) are hydraulic workshop lifts for vehicle underbody servicing. Capacities from 3.5 to 6.8 tons. Asymmetric and symmetric arm styles available with clear-floor and base-plate configurations. Popular in Pakistani workshops for compact footprint and full underbody access.',
        'https://autodiagnostix.com.pk/2-post-car-lifts-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/car-lifts-in-pakistan" class="hover:text-primary transition-colors">Car Lifts</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">2-Post Lifts</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          2-Post Car Lifts in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>2-post car lifts in Pakistan</strong>. Liberty Lifts and UNITE 2-post lifts with capacities from 3.5 to 6.8 tons , for sedans, SUVs, light commercial vehicles and armoured vehicles. Clear-floor and base-plate designs available with delivery, installation guidelines across Pakistan.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">2-Post Lift Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {twoPost.length > 0 ? twoPost.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , 2-post car lift in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">2-Post Lift · {p.brand || 'Workshop'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse our <a href="/car-lifts-in-pakistan" class="text-primary underline">car lift catalog</a> for 2-post lift options.</p>
          )}
        </div>
      </div>
    </section>

    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Choosing the Right 2-Post Lift in Pakistan</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <p>A <strong>2-post car lift</strong> is the most popular lift in Pakistani workshops thanks to its compact footprint, full underbody access, and affordability. When choosing a 2-post lift in Pakistan, consider:</p>
          <ul class="mt-4 space-y-2">
            <li><strong>Capacity</strong>: 3.5T for sedans and small SUVs, 4.5T for full-size SUVs, 6.8T for heavy SUVs, vans and armoured vehicles.</li>
            <li><strong>Arm style</strong>: Symmetric arms (equal length) suit a wide variety of vehicles. Asymmetric arms (different lengths) rotate the vehicle for easier door access.</li>
            <li><strong>Column type</strong>: Clear-floor (no base bar) provides unobstructed floor space; base-plate is the traditional style with a connecting bar.</li>
            <li><strong>Ceiling height</strong>: 2-post lifts require minimum 3.6 m (12 ft) ceiling clearance for most sedans.</li>
            <li><strong>Power</strong>: 3-phase 380V is standard for commercial 2-post lifts in Pakistan.</li>
          </ul>
          <p class="mt-6">We supply the <strong>Liberty TPF-15C 6.8-ton two-post lift</strong> for heavy SUVs, plus 3.5T and 4.5T options for general workshop use. All 2-post lifts come with mechanical safety locks, hydraulic overload protection, and a 1-year warranty backed by Autodiagnostix.</p>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About 2-Post Car Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a 2-Post Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your workshop ceiling height and the vehicles you service , we'll spec the right 2-post lift with delivery and installation.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
