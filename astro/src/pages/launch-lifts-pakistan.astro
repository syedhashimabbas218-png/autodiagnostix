---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const launchLifts = allProducts.filter(p => /tlt|jack stand|floor jack|lh-?330|lh-?340/i.test(p.name));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Launch Lifts in Pakistan', url: 'https://autodiagnostix.com.pk/launch-lifts-pakistan' },
];

const faqs = [
  { question: 'Does Launch make car lifts?', answer: 'Yes , Launch manufactures a focused range of workshop lifting tools, including the TLT440W scissor jack, TLT630A scissor lift, TLT840WAF 4-post lift, the iSmartTLT 242 alignment lift, and the Launch LH-330 / LH-340 dual-pump floor jacks and 3-ton/6-ton jack stands. We supply the complete Launch lifting range in Pakistan.' },
  { question: 'What is the Launch TLT440W?', answer: 'The Launch TLT440W is a 4-ton mobile scissor jack designed for tyre shops and quick-service bays. Compact, fast, and easy to move around the workshop.' },
];
---

<BaseLayout
  title="Buy Launch Lifts in Pakistan | TLT Range &amp; Jacks"
  description="Buy Launch lifts in Pakistan from Autodiagnostix. TLT440W scissor jack, TLT630A, TLT840WAF, iSmartTLT 242, floor jacks &amp; jack stands. Authorized dealer. Delivery across Pakistan including Karachi, Lahore &amp; Islamabad."
  canonical="https://autodiagnostix.com.pk/launch-lifts-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Launch Lifts in Pakistan: TLT Range & Jacks',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Launch Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/launch-lifts-pakistan',
      keywords: ['Launch lifts Pakistan', 'Launch TLT440W', 'Launch TLT630A Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/launch-lifts-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Launch Lifts',
        'Launch lifts are workshop lifting tools manufactured by Launch Tech, including mobile scissor jacks, 4-post lifts, alignment lifts, floor jacks, and jack stands. The TLT range includes the TLT440W scissor jack, TLT630A scissor lift, TLT840WAF 4-post lift, and iSmartTLT 242 alignment scissor.',
        'https://autodiagnostix.com.pk/launch-lifts-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Launch Lifts</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Launch Lifts in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>Launch lifts in Pakistan</strong>. We supply the Launch TLT440W scissor jack, TLT630A scissor lift, TLT840WAF 4-post lift, iSmartTLT 242 alignment lift, plus Launch LH-330/LH-340 dual-pump floor jacks and 3-ton/6-ton jack stands. Workshop-proven, sourced direct from Launch.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Launch Lift Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {launchLifts.length > 0 ? launchLifts.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , Launch lift in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Launch Lift · {p.brand || 'Launch'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse <a href="/brand/launch" class="text-primary underline">all Launch products</a>.</p>
          )}
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Launch Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a Launch Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your workshop needs , we'll recommend the right Launch lift or jack.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
