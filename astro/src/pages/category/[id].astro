---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProducts, getCategory } from '../../lib/payload';
import { breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
const [category, products] = await Promise.all([
  getCategory(id!),
  getProducts(),
]);

if (!category) {
  return Astro.redirect('/404');
}

const filtered = products.filter(p => {
  const catSlug = (p.category || '').toLowerCase().replace(/ & /g, '-').replace(/\s+/g, '-');
  return catSlug === id || p.category === id || p.category?.toLowerCase() === id!.replace(/-/g, ' ');
});

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  { name: category.name, url: `https://autodiagnostix.com/category/${id}` },
];
---

<BaseLayout
  title={category.name}
  description={`Browse ${filtered.length} professional ${category.name} products at Autodiagnostix.`}
  canonical={`https://autodiagnostix.com/category/${id}`}
  jsonLd={breadcrumbListSchema(breadcrumbs)}
>
  <nav class="fixed top-0 w-full z-50 h-16 flex items-center bg-white/70 backdrop-blur-xl border-b border-white/20">
    <div class="flex justify-between items-center w-full px-8 max-w-screen-2xl mx-auto">
      <a href="/">
        <img src="/logo-full.png" alt="Autodiagnostix" class="h-14 w-auto object-contain" />
      </a>
      <a href="/contact" class="bg-primary text-white px-5 py-2 text-xs font-bold uppercase tracking-widest">
        Request a Quote
      </a>
    </div>
  </nav>

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">{category.name}</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">
          {category.name}
        </h1>
        <p class="text-on-surface-variant text-xl max-w-xl">
          {filtered.length} product{filtered.length !== 1 ? 's' : ''}
        </p>
      </div>
    </header>

    <section class="bg-surface-container-low py-14 px-8">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs text-on-surface-variant font-bold uppercase tracking-widest mb-8">
          {filtered.length} product{filtered.length !== 1 ? 's' : ''}
        </p>

        {filtered.length === 0 ? (
          <div class="py-24 text-center text-on-surface-variant text-xl">No products in this category.</div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {filtered.map(product => (
              <a
                href={`/product/${product.id}`}
                class="group bg-surface-container-lowest rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col"
              >
                <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center relative overflow-hidden">
                  {product.heroImages[0] ? (
                    <img
                      src={product.heroImages[0]}
                      alt={product.name}
                      class="w-full h-full object-contain group-hover:scale-105 transition-transform mix-blend-multiply"
                    />
                  ) : (
                    <div class="text-slate-300 text-sm">No image</div>
                  )}
                  {product.badge && (
                    <div class="absolute top-3 right-3 z-10">
                      <span class={`${product.badge === 'NEW' ? 'bg-green-600' : product.badge === 'DISCONTINUED' ? 'bg-red-600' : 'bg-amber-500'} text-white text-[9px] font-black uppercase tracking-widest px-3 py-1 rounded-full shadow-sm`}>
                        {product.badge}
                      </span>
                    </div>
                  )}
                </div>
                <div class="p-6 flex flex-col flex-grow">
                  <p class="text-[10px] font-bold uppercase tracking-widest text-on-surface-variant mb-1">{product.brand}</p>
                  <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{product.name}</h3>
                  <p class="text-on-surface-variant text-xs leading-relaxed mb-6 flex-grow line-clamp-3">{product.summary?.substring(0, 120)}...</p>
                  <span class="text-primary font-bold text-sm flex items-center gap-1 mt-auto pt-4 border-t border-outline-variant/10 group-hover:gap-2 transition-all">
                    View Specs &rarr;
                  </span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  <footer class="bg-zinc-50 border-t border-zinc-200 pt-16 pb-8 px-8">
    <div class="max-w-screen-2xl mx-auto text-center text-zinc-400 text-[10px] uppercase tracking-widest">
      &copy; 2024 Autodiagnostix. All rights reserved.
    </div>
  </footer>
</BaseLayout>
