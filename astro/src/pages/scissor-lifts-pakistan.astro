---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const scissor = allProducts.filter(p => /scissor|fr-|u-z30c|mid-rise/i.test(p.name));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Car Lifts', url: 'https://autodiagnostix.com.pk/car-lifts-in-pakistan' },
  { name: 'Scissor Lifts', url: 'https://autodiagnostix.com.pk/scissor-lifts-pakistan' },
];

const faqs = [
  { question: 'What is a scissor lift used for in a workshop?', answer: 'Scissor lifts in Pakistan are used for tyre shops, quick-service bays, low-ceiling workshops, and wheel alignment. They are more space-efficient than 2-post or 4-post lifts and offer faster raise/lower times.' },
  { question: 'Which scissor lift is best for wheel alignment in Pakistan?', answer: 'The Liberty FR-6108 is a 4.2/5.0-ton scissor lift with integrated alignment turnplates , purpose-built for 3D wheel alignment. For tyre shops, the Liberty FR-6105 3.5-ton and UNITE U-Z30C mid-rise scissor are popular.' },
  { question: 'How much does a scissor lift cost in Pakistan?', answer: 'Scissor lifts in Pakistan range from PKR 350,000 for a small mid-rise to PKR 1,800,000 for a heavy-duty alignment scissor lift, depending on capacity and features.' },
];
---

<BaseLayout
  title="Buy Scissor Lifts in Pakistan | Liberty &amp; UNITE"
  description="Buy scissor lifts in Pakistan from Autodiagnostix. Authorized Liberty Lifts &amp; UNITE dealer. 3.5T to 5T capacities. Prices PKR 350,000–1,800,000. For tyre shops &amp; alignment. Delivery Karachi, Lahore, Islamabad &amp; all Pakistan."
  canonical="https://autodiagnostix.com.pk/scissor-lifts-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Scissor Lifts in Pakistan: Liberty & UNITE',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Scissor Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/scissor-lifts-pakistan',
      keywords: ['scissor lifts Pakistan', 'mid-rise scissor lift Pakistan', 'alignment scissor lift Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/scissor-lifts-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Scissor Lifts',
        'Scissor lifts are space-efficient workshop lifts that raise vehicles using a scissor-style mechanism. Used in tyre shops, quick-service bays, alignment bays, and low-ceiling workshops. Capacities from 3.5 to 5 tons in Pakistan.',
        'https://autodiagnostix.com.pk/scissor-lifts-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <a href="/car-lifts-in-pakistan" class="hover:text-primary transition-colors">Car Lifts</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Scissor Lifts</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Scissor Lifts in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>scissor lifts in Pakistan</strong>. Liberty Lifts FR-6105, FR-6108 and UNITE U-Z30C mid-rise scissor lifts , ideal for tyre shops, quick-service bays, low-ceiling workshops and 3D wheel alignment. Delivery and installation across Pakistan.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Scissor Lift Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {scissor.length > 0 ? scissor.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , scissor lift in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Scissor Lift · {p.brand || 'Workshop'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse our <a href="/car-lifts-in-pakistan" class="text-primary underline">car lift catalog</a>.</p>
          )}
        </div>
      </div>
    </section>

    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Why Choose a Scissor Lift?</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <p><strong>Scissor lifts in Pakistan</strong> are the go-to choice for tyre shops, body shops, and workshops with low ceilings. Their compact footprint, low rise height, and fast lift/lower times make them ideal for high-throughput bays. The <strong>UNITE U-Z30C</strong> is a mobile mid-rise scissor lift , perfect for quick-service jobs like brake work and tyre changes.</p>
          <p class="mt-4">For wheel alignment, the <strong>Liberty FR-6108</strong> 4.2/5.0-ton alignment scissor lift is purpose-built with integrated turnplates and rear slip plates, supporting modern 3D aligners like the Launch WA613 and X861 PRO.</p>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Scissor Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      details[open] .geo-answer,

      details[open] > p:last-of-type {

        animation: faqFadeIn 0.2s ease-out;

      }

      @keyframes faqFadeIn {

        from { opacity: 0; transform: translateY(-6px); }

        to { opacity: 1; transform: translateY(0); }

      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a Scissor Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your workshop bay dimensions , we'll recommend the right scissor lift with delivery and installation.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
