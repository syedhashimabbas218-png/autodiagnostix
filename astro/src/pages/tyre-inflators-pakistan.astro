---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const inflators = allProducts.filter(p => /inflator|hp-?2690a|hj-?937|nitrogen/i.test(p.name + ' ' + p.summary));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Tyre Inflators in Pakistan', url: 'https://autodiagnostix.com.pk/tyre-inflators-pakistan' },
];

const faqs = [
  { question: 'Do you sell nitrogen tyre inflators in Pakistan?', answer: 'Yes , Autodiagnostix is Pakistan\'s authorized dealer for UNITE nitrogen tyre inflators. We supply the UNITE HP-2690A/4EN and HJ 937 wall-mounted nitrogen inflators, ideal for tyre shops, dealerships, and service centers.' },
  { question: 'Why use nitrogen for tyres?', answer: 'Nitrogen tyres maintain pressure longer than air, reduce tyre wear, improve fuel economy, and prevent rim corrosion. Nitrogen is widely used in commercial vehicles, race cars, and high-end passenger vehicles. UNITE nitrogen inflators in Pakistan are the OEM choice for many dealerships.' },
];
---

<BaseLayout
  title="Buy Nitrogen Tyre Inflators Pakistan | UNITE HP-2690A"
  description="Buy nitrogen tyre inflators in Pakistan from Autodiagnostix. UNITE HP-2690A/4EN &amp; HJ 937 wall-mounted. For tyre shops, dealerships. Delivery &amp; installation across Pakistan including Karachi, Lahore &amp; Islamabad."
  canonical="https://autodiagnostix.com.pk/tyre-inflators-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Nitrogen Tyre Inflators in Pakistan: UNITE HP-2690A',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Nitrogen Tyre Inflators in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/tyre-inflators-pakistan',
      keywords: ['nitrogen tyre inflator Pakistan', 'UNITE HP-2690A', 'tyre inflator Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/tyre-inflators-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Tyre Inflators',
        'Tyre inflators are garage equipment used to inflate vehicle tyres with compressed air or nitrogen. Nitrogen tyre inflators maintain tyre pressure longer, reduce wear, and improve fuel economy. The UNITE HP-2690A/4EN and HJ 937 are popular nitrogen inflators in Pakistan.',
        'https://autodiagnostix.com.pk/tyre-inflators-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Tyre Inflators</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Nitrogen Tyre Inflators in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>nitrogen tyre inflators in Pakistan</strong>. We supply the UNITE <a href="/product/hp-2690a-4en" class="text-primary hover:underline">HP-2690A/4EN</a> and <a href="/product/hj-937" class="text-primary hover:underline">HJ 937</a> wall-mounted nitrogen inflators. Ideal for tyre shops, dealerships, and high-volume service centers.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Nitrogen Inflator Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {inflators.length > 0 ? inflators.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , nitrogen tyre inflator in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Nitrogen Inflator · {p.brand || 'UNITE'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse <a href="/brand/unite" class="text-primary underline">all UNITE products</a>.</p>
          )}
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Tyre Inflators in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a Tyre Inflator Quote</h2>
        <p class="mb-8 text-white/80">Tell us your shop size , we'll recommend the right UNITE nitrogen inflator.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
