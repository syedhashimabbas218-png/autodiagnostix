---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbListSchema } from '../utils/schema';

export const prerender = false;

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'About', url: 'https://autodiagnostix.com.pk/about' },
];
---

<BaseLayout
  title="About Us"
  description="Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE automotive diagnostic equipment."
  canonical="https://autodiagnostix.com.pk/about"
  jsonLd={breadcrumbListSchema(breadcrumbs)}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-surface pt-20 pb-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10" />
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-bl from-primary/8 via-transparent to-transparent" />
      <div class="relative max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-8">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">About</span>
        </nav>
        <div class="max-w-3xl">
          <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            About <span class="text-primary">Autodiagnostix</span>
          </h1>
          <p class="text-on-surface-variant text-xl md:text-2xl leading-relaxed max-w-2xl">
            Your trusted partner for professional automotive diagnostic equipment in Pakistan.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="relative -mt-12 px-8 pb-20">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">precision_manufacturing</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">50+</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Products Available</p>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">workspace_premium</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">4</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Premium Brands</p>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">category</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">8</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Product Categories</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Who We Are -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Who We Are</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            Pakistan's Authorized Dealer for World-Class Diagnostic Equipment
          </h2>
          <div class="space-y-4 text-on-surface-variant leading-relaxed">
            <p>Autodiagnostix is Pakistan's authorized dealer for LAUNCH, SMARTSAFE, and UNITE automotive diagnostic equipment. We bring globally trusted diagnostic technology to workshops and service centers across the country.</p>
            <p>Our product range covers professional-grade diagnostic scanners, wheel alignment systems, lifting equipment, ADAS calibration tools, and EV battery service equipment — everything a modern workshop needs.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-10 border border-outline-variant/20">
          <div class="flex items-start gap-4 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">verified</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Authorized Distributor</h3>
              <p class="text-sm text-on-surface-variant mt-1">Officially partnered with LAUNCH and SMARTSAFE for the Pakistani market.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">support_agent</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Technical Support</h3>
              <p class="text-sm text-on-surface-variant mt-1">Comprehensive after-sales support, training, and technical assistance.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">local_shipping</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Pan-Pakistan Delivery</h3>
              <p class="text-sm text-on-surface-variant mt-1">Reliable shipping to workshops and service centers nationwide.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-20 px-8 bg-surface">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-last lg:order-first">
          <div class="bg-surface-container-low rounded-xl p-10 border border-outline-variant/10 relative">
            <div class="absolute top-0 left-0 w-1 h-full bg-primary rounded-full" />
            <blockquote class="text-on-surface-variant text-lg italic leading-relaxed pl-6">
              "Every tool we supply is backed by comprehensive technical support, training resources, and genuine after-sales service."
            </blockquote>
          </div>
        </div>
        <div class="order-first lg:order-last">
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Our Mission</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            Equipping Professionals with World-Class Technology
          </h2>
          <p class="text-on-surface-variant leading-relaxed text-lg">
            We equip Pakistani automotive professionals with the same world-class diagnostic technology used by leading workshops globally. Every tool we supply is backed by comprehensive technical support, training resources, and after-sales service.
          </p>
        </div>
      </div>
    </section>

    <!-- Brands -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Our Brands</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-4">
            Trusted Manufacturers
          </h2>
          <p class="text-on-surface-variant max-w-xl mx-auto">We partner with the world's leading automotive diagnostic equipment manufacturers.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-2xl">build</span>
              </div>
              <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">LAUNCH</h3>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Global leader in automotive diagnostic technology, known for the X-431 series scanners, ADAS calibration systems, and comprehensive workshop solutions.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-2xl">settings</span>
              </div>
              <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">SMARTSAFE</h3>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Specialist in wheel alignment and lifting equipment, delivering precision 3D alignment systems and heavy-duty workshop lifts.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-2xl">cleaning_services</span>
              </div>
              <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">UNITE</h3>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Manufacturer of fuel injector cleaners and A/C service stations, trusted by workshops for reliable maintenance equipment.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-12 h-12 rounded-lg bg-primary/10 flex items-center justify-center shrink-0">
                <span class="material-symbols-outlined text-primary text-2xl">handyman</span>
              </div>
              <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">AUTOOL</h3>
            </div>
            <p class="text-on-surface-variant leading-relaxed">Provider of specialized diagnostic and testing tools including spark plug testers and injector testers for professional technicians.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="relative overflow-hidden py-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#a50a18] to-[#7d000b]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.12),transparent_50%)]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(255,255,255,0.06),transparent_40%)]" />
      <div class="relative max-w-3xl mx-auto text-center">
        <span class="text-xs font-label uppercase tracking-widest text-white/70 font-bold mb-4 block">Get in Touch</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-white mb-6 leading-[1.08]">
          Ready to Upgrade Your Workshop?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-lg mx-auto leading-relaxed">
          Contact us for pricing, technical details, or a personalized demo of any product in our catalog.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white text-primary font-extrabold px-10 py-4 text-sm uppercase tracking-widest rounded-lg hover:bg-white/90 hover:scale-[0.97] transition-all duration-200">
          Contact Us
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
