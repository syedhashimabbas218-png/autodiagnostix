---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { breadcrumbListSchema, organizationSchema, localBusinessSchema, faqSchema } from '../utils/schema';

const aboutFaqs = [
  { question: 'What is Autodiagnostix?', answer: 'Autodiagnostix is Pakistan\'s authorized dealer for LAUNCH, SMARTSAFE, UNITE, Liberty Lifts, GTI.tools and AUTOOL, supplying professional automotive diagnostic scanners, car lifts, 3D wheel aligners, tyre changers, wheel balancers, ADAS calibration, EV diagnostics, battery testers, and videoscopes to workshops across Pakistan.' },
  { question: 'Where is Autodiagnostix based?', answer: 'Our head office is in Shalimar Town, Main Bypass Road, Sahiwal, Punjab, Pakistan. We deliver equipment across Pakistan and provide installation guidelines to every workshop we serve.' },
  { question: 'Which brands does Autodiagnostix supply?', answer: 'We are Pakistan\'s authorized dealer for LAUNCH (diagnostics, ADAS, EV), SMARTSAFE (battery tools, videoscopes), UNITE (lifts, inflators, alignment), Liberty Lifts (heavy-duty lifts), GTI.tools (German-engineered tyre changers and wheel balancers), and AUTOOL (specialty tools).' },
];

export const prerender = false;

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'About', url: 'https://autodiagnostix.com.pk/about' },
];
---

<BaseLayout
  title="About Autodiagnostix | Pakistan's Authorized Dealer"
  description="Autodiagnostix is Pakistan's authorized dealer for LAUNCH, SMARTSAFE, UNITE, GTI.tools, Liberty Lifts and AUTOOL. We supply professional automotive diagnostic equipment, car lifts, wheel alignment, tyre changers, ADAS, EV tools and workshop equipment across Pakistan."
  canonical="https://autodiagnostix.com.pk/about"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), localBusinessSchema(), faqSchema(aboutFaqs)]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <!-- Hero -->
    <section class="relative overflow-hidden bg-surface pt-20 pb-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary/5 via-transparent to-primary/10" />
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-bl from-primary/8 via-transparent to-transparent" />
      <div class="relative max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-8">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">About</span>
        </nav>
        <div class="max-w-3xl">
          <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            About <span class="text-primary">Autodiagnostix</span>
          </h1>
          <p class="text-on-surface-variant text-xl md:text-2xl leading-relaxed max-w-2xl">
            Your trusted partner for professional automotive diagnostic equipment in Pakistan.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="relative -mt-12 px-8 pb-20">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">precision_manufacturing</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">50+</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Products Available</p>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">workspace_premium</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">6</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Authorized Brands</p>
          </div>
          <div class="bg-surface-container-lowest rounded-xl p-8 shadow-sm border border-outline-variant/20 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <span class="material-symbols-outlined text-3xl text-primary mb-4">category</span>
            <div class="text-4xl md:text-5xl font-headline font-extrabold text-primary mb-1">8</div>
            <p class="text-sm text-on-surface-variant font-medium uppercase tracking-wider">Product Categories</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Who We Are -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Who We Are</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            Pakistan's Authorized Dealer for World-Class Diagnostic Equipment
          </h2>
          <div class="space-y-4 text-on-surface-variant leading-relaxed">
            <p>Autodiagnostix is Pakistan's authorized dealer for LAUNCH, SMARTSAFE, and UNITE automotive diagnostic equipment. We bring globally trusted diagnostic technology to workshops and service centers across the country.</p>
            <p>Our product range covers professional-grade diagnostic scanners, wheel alignment systems, lifting equipment, ADAS calibration tools, and EV battery service equipment , everything a modern workshop needs.</p>
          </div>
        </div>
        <div class="bg-surface-container-lowest rounded-xl p-10 border border-outline-variant/20">
          <div class="flex items-start gap-4 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">verified</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Authorized Distributor</h3>
              <p class="text-sm text-on-surface-variant mt-1">Officially partnered with LAUNCH and SMARTSAFE for the Pakistani market.</p>
            </div>
          </div>
          <div class="flex items-start gap-4 mb-6">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">support_agent</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Technical Support</h3>
              <p class="text-sm text-on-surface-variant mt-1">Comprehensive after-sales support and technical assistance.</p>
            </div>
          </div>
          <div class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary text-2xl mt-0.5">local_shipping</span>
            <div>
              <h3 class="font-headline font-bold text-lg text-on-surface">Pan-Pakistan Delivery</h3>
              <p class="text-sm text-on-surface-variant mt-1">Reliable shipping to workshops and service centers nationwide.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="py-20 px-8 bg-surface">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-last lg:order-first">
          <div class="bg-surface-container-low rounded-xl p-10 border border-outline-variant/10 relative">
            <div class="absolute top-0 left-0 w-1 h-full bg-primary rounded-full" />
            <blockquote class="text-on-surface-variant text-lg italic leading-relaxed pl-6">
              "Every tool we supply is backed by comprehensive technical support and genuine after-sales service."
            </blockquote>
          </div>
        </div>
        <div class="order-first lg:order-last">
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Our Mission</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
            Equipping Professionals with World-Class Technology
          </h2>
          <p class="text-on-surface-variant leading-relaxed text-lg">
            We equip Pakistani automotive professionals with the same world-class diagnostic technology used by leading workshops globally. Every tool we supply is backed by comprehensive technical support and after-sales service.
          </p>
        </div>
      </div>
    </section>

    <!-- Brands -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Our Brands</span>
          <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-on-surface mb-4">
            Trusted Manufacturers
          </h2>
          <p class="text-on-surface-variant max-w-xl mx-auto">We partner with the world's leading automotive diagnostic equipment manufacturers.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/launch.webp" alt="LAUNCH automotive diagnostic equipment" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">LAUNCH</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">Global leader in automotive diagnostic technology, X-431 PRO3 LINK, PAD 9 LINK, CNC 605A, ADAS PRO PLUS, HD III heavy-duty, EV toolkit, 3D wheel aligners, videoscopes, and workshop lifting tools.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/liberty-lifts.webp" alt="Liberty Lifts heavy-duty vehicle lifts" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">Liberty Lifts</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">Heavy-duty workshop lifts, 2-post, 4-post, scissor, alignment, and bulletproof vehicle lifts. 3.5 to 6.8 ton capacities for Pakistani workshops.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/gti-tools.webp" alt="GTI.tools German-engineered tyre changers and wheel balancers" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">GTI.tools</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">German-engineered tyre changers (G-Extreme, POWER X, RFT PRO) and automatic wheel balancers (LCD Premium with sonar system) for high-volume tyre shops.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/smartsafe.webp" alt="Smartsafe battery testers and videoscopes" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">SMARTSAFE</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">Professional diagnostic and inspection tools, battery testers, videoscopes, and 3D wheel aligners trusted by workshops worldwide.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/unite.webp" alt="UNITE workshop and tyre service equipment" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">UNITE</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">Workshop and tyre-service equipment, 4-post lifts, scissor lifts, mobile lifts, 3D wheel aligners, and nitrogen tyre inflators.</p>
          </div>
          <div class="group bg-surface-container-lowest rounded-xl p-8 border border-outline-variant/20 hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="h-12 mb-4 flex items-center">
              <img src="/images/brands/autool.webp" alt="AUTOOL specialized diagnostic and service tools" class="max-h-12 max-w-full object-contain" width="200" height="48" loading="lazy" />
            </div>
            <h3 class="font-headline font-bold text-xl text-on-surface group-hover:text-primary transition-colors">AUTOOL</h3>
            <p class="text-on-surface-variant leading-relaxed mt-3">Provider of specialized diagnostic and testing tools including spark plug testers and injector testers for professional technicians.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SEO CONTENT -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <span class="text-xs font-label uppercase tracking-widest text-primary font-bold mb-3 block">Why Autodiagnostix</span>
        <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tighter text-on-surface mb-6">Pakistan's Most Trusted Workshop Equipment Partner</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant space-y-4">
          <p>Autodiagnostix is more than a dealer, we are a complete workshop solutions partner. From the moment you contact us, our team helps you select the right equipment for your workshop, arrange delivery, install on-site, and provide ongoing warranty and after-sales support.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-2">What We Supply</h3>
          <p>Our product range covers every major category of professional automotive workshop equipment: <a href="/launch-x431-pakistan" class="text-primary underline">Launch X431 diagnostic scanners</a>, <a href="/car-lifts-in-pakistan" class="text-primary underline">car lifts</a> (2-post, 4-post, scissor, alignment, bulletproof), <a href="/wheel-alignment-in-pakistan" class="text-primary underline">3D wheel alignment</a>, <a href="/tyre-changers-pakistan" class="text-primary underline">tyre changers</a>, <a href="/wheel-balancers-pakistan" class="text-primary underline">wheel balancers</a>, <a href="/adas-calibration-pakistan" class="text-primary underline">ADAS calibration</a>, <a href="/ev-diagnostics-pakistan" class="text-primary underline">EV diagnostics</a>, <a href="/battery-testers-pakistan" class="text-primary underline">battery testers</a>, <a href="/videoscope-pakistan" class="text-primary underline">videoscopes</a>, <a href="/launch-injector-machines-pakistan" class="text-primary underline">injector machines</a>, and <a href="/tyre-inflators-pakistan" class="text-primary underline">nitrogen tyre inflators</a>.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-2">Our Service Promise</h3>
          <p>Every product we sell is genuine, sourced direct from the manufacturer, and backed by a full warranty. Our team provides delivery and installation guidelines to workshops across Pakistan. We also maintain local inventory of consumables, accessories, and spare parts to keep your workshop running.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-2">Who We Serve</h3>
          <p>Autodiagnostix supplies independent workshops, dealership service centers, tyre shops, body shops, fleet operators, government workshops, banks and security fleets, EV service centers, and OEMs. Whether you are setting up a single-bay garage or a multi-bay service center, we have the equipment range and expertise to help.</p>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-10">About Autodiagnostix , FAQ</h2>
        <div class="space-y-4" data-accordion>
          {aboutFaqs.map(f => (
            <details class="group border border-zinc-100 rounded-lg p-6 bg-white">
              <summary class="cursor-pointer font-headline font-bold text-on-surface text-lg flex justify-between items-center list-none">
                <span>{f.question}</span>
                <span class="text-primary text-2xl group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="mt-4 text-on-surface-variant leading-relaxed">{f.answer}</p>
            </details>
          ))}
        </div>
      </div>
      <script>
        (() => {
          const group = document.querySelector('[data-accordion]');
          if (!group) return;
          const details = group.querySelectorAll('details');
          details.forEach(d => {
            const s = d.querySelector('summary');
            if (!s) return;
            s.addEventListener('click', (e) => {
              e.preventDefault();
              details.forEach(el => { if (el !== d) el.open = false; });
              d.open = !d.open;
            });
          });
        })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <!-- CTA -->
    <section class="relative overflow-hidden py-24 px-8">
      <div class="absolute inset-0 bg-gradient-to-br from-primary via-[#a50a18] to-[#7d000b]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(255,255,255,0.12),transparent_50%)]" />
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(255,255,255,0.06),transparent_40%)]" />
      <div class="relative max-w-3xl mx-auto text-center">
        <span class="text-xs font-label uppercase tracking-widest text-white/70 font-bold mb-4 block">Get in Touch</span>
        <h2 class="font-headline text-4xl md:text-5xl font-extrabold tracking-tighter text-white mb-6 leading-[1.08]">
          Ready to Upgrade Your Workshop?
        </h2>
        <p class="text-white/80 text-lg mb-10 max-w-lg mx-auto leading-relaxed">
          Contact us for pricing, technical details, or a personalized demo of any product in our catalog.
        </p>
        <a href="/contact" class="inline-flex items-center gap-2 bg-white text-primary font-extrabold px-10 py-4 text-sm uppercase tracking-widest rounded-lg hover:bg-white/90 hover:scale-[0.97] transition-all duration-200">
          Contact Us
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
