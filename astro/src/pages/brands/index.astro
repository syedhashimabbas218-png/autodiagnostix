---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getBrands } from '../../lib/payload';
import { breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

const brands = await getBrands();

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  { name: 'Brands', url: 'https://autodiagnostix.com/brands' },
];
---

<BaseLayout
  title="Brands"
  description="Browse industry-leading diagnostic tool manufacturers at Autodiagnostix. Explore Launch, Autel, and more."
  canonical="https://autodiagnostix.com/brands"
  jsonLd={breadcrumbListSchema(breadcrumbs)}
>
  <nav class="fixed top-0 w-full z-50 h-16 flex items-center bg-white/70 backdrop-blur-xl border-b border-white/20">
    <div class="flex justify-between items-center w-full px-8 max-w-screen-2xl mx-auto">
      <a href="/">
        <img src="/logo-full.png" alt="Autodiagnostix" class="h-14 w-auto object-contain" />
      </a>
      <a href="/contact" class="bg-primary text-white px-5 py-2 text-xs font-bold uppercase tracking-widest">
        Request a Quote
      </a>
    </div>
  </nav>

  <main class="min-h-screen pt-20">
    <header class="bg-surface pt-16 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Brands</span>
        </nav>
        <h1 class="font-headline text-5xl md:text-7xl font-extrabold tracking-tighter text-on-surface mb-4">Our Brands</h1>
        <p class="text-on-surface-variant text-xl max-w-xl">Industry-leading manufacturers powering professional workshops worldwide.</p>
      </div>
    </header>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {brands.map(brand => (
          <a
            href={`/brand/${brand.slug}`}
            class="group block bg-surface-container-lowest rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1"
          >
            <div class="aspect-[16/7] bg-white p-8 flex items-center justify-center overflow-hidden">
              {brand.image ? (
                <img src={brand.image} alt={brand.name} class="max-h-24 max-w-full object-contain group-hover:scale-105 transition-transform mix-blend-multiply" />
              ) : (
                <div class="text-3xl font-headline font-bold text-slate-300">{brand.name.charAt(0)}</div>
              )}
            </div>
            <div class="p-6 flex items-center justify-between">
              <div>
                <h2 class="font-headline font-extrabold text-xl tracking-tight group-hover:text-primary transition-colors">{brand.name}</h2>
                <p class="text-xs text-on-surface-variant mt-0.5">{brand.productCount} product{brand.productCount !== 1 ? 's' : ''}</p>
              </div>
              <span class="text-on-surface-variant group-hover:text-primary group-hover:translate-x-1 transition-all">&rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <footer class="bg-zinc-50 border-t border-zinc-200 pt-16 pb-8 px-8">
    <div class="max-w-screen-2xl mx-auto text-center text-zinc-400 text-[10px] uppercase tracking-widest">
      &copy; 2024 Autodiagnostix. All rights reserved.
    </div>
  </footer>
</BaseLayout>
