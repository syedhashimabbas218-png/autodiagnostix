---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FeatureList from '../../components/FeatureList.astro';
import ProductGallery from '../../components/ProductGallery';
import { getProduct } from '../../lib/strapi';
import { productSchema, breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
let product = null;
try {
  product = await getProduct(id!);
} catch {
  // CMS offline
}

if (!product) {
  return Astro.redirect('/404');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  {
    name: product.category || 'Products',
    url: `https://autodiagnostix.com.pk/category/${(product.category || '').toLowerCase().replace(/ & /g, '-').replace(/\s+/g, '-')}`,
  },
  { name: product.name, url: `https://autodiagnostix.com.pk/product/${id}` },
];
---

<BaseLayout
  title={`${product.name} in Pakistan`}
  description={product.summary || product.description?.substring(0, 160) || `${product.name} , buy in Pakistan from Autodiagnostix. Authorized dealer for ${product.brand || 'premium brands'}.`}
  canonical={`https://autodiagnostix.com.pk/product/${id}`}
  ogType="product"
  ogImage={product.heroImages?.[0] || undefined}
  jsonLd={[productSchema(product), breadcrumbListSchema(breadcrumbs)]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20 bg-surface-container-lowest">
    <section class="flex flex-col items-center justify-center text-center px-6 py-24">
      <div class="flex flex-wrap items-center justify-center gap-2 mb-6">
        {(product.brands.length > 0 ? product.brands : [product.brand]).filter(Boolean).map(b => (
          <span class="inline-block px-4 py-1.5 text-[10px] font-bold tracking-[0.2em] uppercase bg-surface-container-high rounded-full text-on-surface-variant font-label">
            {b}
          </span>
        ))}
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-headline font-extrabold tracking-tighter text-on-surface leading-[1.05] mb-8 max-w-5xl">
        {product.name}
        {product.badge && (
          <span class={`ml-4 align-middle text-xs px-3 py-1 rounded-full text-white font-black tracking-widest ${product.badge === 'NEW' ? 'bg-green-600' : product.badge === 'DISCONTINUED' ? 'bg-red-600' : 'bg-amber-500'}`}>
            {product.badge}
          </span>
        )}
      </h1>
      <p class="text-base md:text-lg text-slate-500 max-w-4xl mx-auto leading-relaxed mb-12">{product.summary}</p>

      {product.heroImages.length > 0 && (
        <div class="w-full max-w-5xl aspect-video bg-white rounded-2xl overflow-hidden shadow-sm border border-black/5">
          <img class="w-full h-full object-contain p-8 mix-blend-multiply" src={product.heroImages[0]} alt={product.name} width="800" height="600" />
        </div>
      )}
    </section>

    {product.features.length > 0 && (
      <FeatureList
        eyebrow="Highlights"
        title="Key Features"
        headingId="key-features-heading"
        items={product.features}
      />
    )}

    {product.heroImages.length > 1 && (
      <ProductGallery
        client:visible
        images={product.heroImages.map((url, i) => ({ id: i, url, alt: `${product.name} image ${i + 1}` }))}
        productName={product.name}
      />
    )}

    {product.functions.length > 0 && (
      <FeatureList
        eyebrow="Capabilities"
        title="Functions"
        headingId="functions-heading"
        items={product.functions}
      />
    )}

    {product.technicalTable.length > 0 && (
      <section class="py-24 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
          <h2 class="text-4xl font-headline font-extrabold tracking-tighter mb-16">TECHNICAL SPECIFICATIONS</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-0.5 bg-outline-variant/20 border border-outline-variant/20 rounded-xl overflow-hidden">
            {product.technicalTable.map(spec => (
              <div class="bg-surface-container-lowest p-10 flex flex-col gap-4">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase">{spec.label}</span>
                <div class="text-2xl font-headline font-medium">{spec.value}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="fixed bottom-0 left-0 w-full bg-white/80 backdrop-blur-xl border-t border-slate-100 z-50">
      <div class="max-w-7xl mx-auto h-24 px-8 flex items-center justify-between gap-4">
        <div class="hidden sm:block">
          <h3 class="font-headline font-bold text-lg text-on-surface">{product.name}</h3>
          <p class="text-xs text-slate-500 font-label tracking-wide">{product.brand}</p>
        </div>
        <div class="flex items-center gap-3 ml-auto">
          <a
            href={`/api/product-pdf/${product.id}`}
            download
            class="border border-primary-container text-primary-container px-5 sm:px-6 h-12 rounded-full font-headline font-bold text-xs sm:text-sm uppercase tracking-[0.1em] flex items-center gap-2 hover:bg-primary-container/5 transition-all"
            aria-label="Download technical sheet PDF"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            <span class="hidden sm:inline">Technical Sheet</span>
            <span class="sm:hidden">PDF</span>
          </a>
          <a href="/contact" class="bg-primary-container text-white px-6 sm:px-8 h-12 rounded-full font-headline font-bold text-sm uppercase tracking-[0.1em] shadow-xl flex items-center hover:-translate-y-1 transition-all">
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
