---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getProduct } from '../../lib/payload';
import { productSchema, breadcrumbListSchema } from '../../utils/schema';

export const prerender = false;

const { id } = Astro.params;
let product = null;
try {
  product = await getProduct(id!);
} catch {
  // CMS offline
}

if (!product) {
  return Astro.redirect('/404');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com/' },
  {
    name: product.category || 'Products',
    url: `https://autodiagnostix.com/category/${(product.category || '').toLowerCase().replace(/ & /g, '-').replace(/\s+/g, '-')}`,
  },
  { name: product.name, url: `https://autodiagnostix.com/product/${id}` },
];
---

<BaseLayout
  title={product.name}
  description={product.summary || product.description?.substring(0, 160) || ''}
  canonical={`https://autodiagnostix.com/product/${id}`}
  ogType="product"
  ogImage={product.heroImages?.[0] || undefined}
  jsonLd={[productSchema(product), breadcrumbListSchema(breadcrumbs)]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-20 bg-surface-container-lowest">
    <section class="flex flex-col items-center justify-center text-center px-6 py-24">
      <span class="inline-block px-4 py-1.5 mb-6 text-[10px] font-bold tracking-[0.2em] uppercase bg-surface-container-high rounded-full text-on-surface-variant font-label">
        {product.brand}
      </span>
      <h1 class="text-6xl md:text-8xl font-headline font-extrabold tracking-tighter text-on-surface leading-[0.9] mb-8">
        {product.name}
        {product.badge && (
          <span class={`ml-4 align-middle text-xs px-3 py-1 rounded-full text-white font-black tracking-widest ${product.badge === 'NEW' ? 'bg-green-600' : product.badge === 'DISCONTINUED' ? 'bg-red-600' : 'bg-amber-500'}`}>
            {product.badge}
          </span>
        )}
      </h1>
      <p class="text-xl md:text-2xl text-slate-500 max-w-2xl mx-auto leading-relaxed mb-12">{product.summary}</p>

      {product.heroImages.length > 0 && (
        <div class="w-full max-w-5xl aspect-video bg-white rounded-2xl overflow-hidden shadow-sm border border-black/5">
          <img class="w-full h-full object-contain p-8 mix-blend-multiply" src={product.heroImages[0]} alt={product.name} />
        </div>
      )}
    </section>

    {product.features.length > 0 && (
      <section class="py-24 bg-surface">
        <div class="max-w-7xl mx-auto px-8 grid grid-cols-1 md:grid-cols-2 gap-16">
          {product.features.map(feat => (
            <div class="bg-surface-container-lowest p-10 rounded-2xl border border-outline-variant/10">
              <h2 class="text-3xl font-headline font-bold tracking-tight text-on-surface mb-4">{feat.title}</h2>
              <p class="text-slate-600 leading-relaxed">{feat.description}</p>
            </div>
          ))}
        </div>
      </section>
    )}

    {product.technicalTable.length > 0 && (
      <section class="py-24 bg-surface-container-lowest">
        <div class="max-w-7xl mx-auto px-8">
          <h2 class="text-4xl font-headline font-extrabold tracking-tighter mb-16">TECHNICAL SPECIFICATIONS</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-0.5 bg-outline-variant/20 border border-outline-variant/20 rounded-xl overflow-hidden">
            {product.technicalTable.map(spec => (
              <div class="bg-surface-container-lowest p-10 flex flex-col gap-4">
                <span class="text-[10px] font-bold tracking-widest text-slate-400 uppercase">{spec.label}</span>
                <div class="text-2xl font-headline font-medium">{spec.value}</div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <div class="fixed bottom-0 left-0 w-full bg-white/80 backdrop-blur-xl border-t border-slate-100 z-50">
      <div class="max-w-7xl mx-auto h-24 px-8 flex items-center justify-between">
        <div class="hidden sm:block">
          <h3 class="font-headline font-bold text-lg text-on-surface">{product.name}</h3>
          <p class="text-xs text-slate-500 font-label tracking-wide">{product.brand}</p>
        </div>
        <a href="/contact" class="bg-primary-container text-white px-8 h-12 rounded-full font-headline font-bold text-sm uppercase tracking-[0.1em] shadow-xl flex items-center hover:-translate-y-1 transition-all">
          Request a Quote
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
