---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const lifts = allProducts.filter(p => /lift|jack stand|scissor|two-post|four-post|2-post|4-post/i.test(p.name + ' ' + p.category));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Car Lifts in Pakistan', url: 'https://autodiagnostix.com.pk/car-lifts-in-pakistan' },
];

const faqs = [
  { question: 'How much does a 2-post car lift cost in Pakistan?', answer: 'Two-post lifts in Pakistan typically range from PKR 450,000 to PKR 1,200,000 depending on capacity (3.5 to 6.8 ton), brand (Liberty Lifts, UNITE) and features. The Liberty TPF-15C 6.8-ton two-post lift is our heaviest-duty option for SUVs and commercial vehicles.' },
  { question: 'What is the best car lift for a workshop in Pakistan?', answer: 'For most Pakistani workshops, a 4-ton to 5-ton two-post lift (clear-floor) is ideal for general servicing, while a 4-post lift is best for wheel alignment. For tyre shops, a scissor lift with alignment integration is recommended. We supply Liberty Lifts and UNITE , both proven in Pakistan.' },
  { question: 'Do you deliver car lifts outside Karachi and Lahore?', answer: 'Yes, we deliver car lifts, scissor lifts and 4-post lifts to all cities across Pakistan. Installation guidelines are provided with every order.' },
  { question: 'Are bulletproof vehicle lifts available in Pakistan?', answer: 'Yes. We supply heavy-duty bulletproof / armoured-vehicle lifts from UNITE and Liberty Lifts, with capacities from 4 to 8 tons, designed for armoured SUVs and cash-transit vehicles used by banks and security fleets.' },
];
---

<BaseLayout
  title="Car Lifts in Pakistan , 2-Post, 4-Post, Scissor & Bulletproof Lifts"
  description="Buy car lifts in Pakistan from Autodiagnostix , Pakistan's authorized dealer for Liberty Lifts and UNITE. 2-post lifts, 4-post lifts, scissor lifts, alignment lifts and bulletproof vehicle lifts. Delivery & installation in Karachi, Lahore, Islamabad & all Pakistan."
  canonical="https://autodiagnostix.com.pk/car-lifts-in-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Car Lifts in Pakistan: 2-Post, 4-Post, Scissor & Bulletproof Lifts',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Car Lifts in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/car-lifts-in-pakistan',
      keywords: ['car lifts Pakistan', '2-post lifts Pakistan', '4-post lifts Pakistan', 'scissor lifts Pakistan', 'Liberty Lifts Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/car-lifts-in-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Car Lifts',
        'Car lifts are hydraulic or electro-mechanical workshop tools that raise vehicles for underbody servicing, tyre changes, wheel alignment, and inspection. Types include 2-post lifts (3.5–6.8 ton capacity for general servicing), 4-post lifts (for alignment and storage), scissor lifts (space-saving for low-ceiling shops), and alignment lifts. Leading brands in Pakistan include Liberty Lifts and UNITE, supplied by Autodiagnostix with delivery, installation, and training nationwide.',
        'https://autodiagnostix.com.pk/car-lifts-in-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Car Lifts in Pakistan</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Car Lifts in Pakistan, 2-Post, 4-Post, Scissor &amp; Bulletproof
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Pakistan's authorized dealer for <strong>Liberty Lifts</strong> and <strong>UNITE</strong> car lifts. We supply <a href="/2-post-car-lifts-pakistan" class="text-primary hover:underline">2-post lifts</a>, <a href="/4-post-car-lifts-pakistan" class="text-primary hover:underline">4-post lifts</a>, <a href="/scissor-lifts-pakistan" class="text-primary hover:underline">scissor lifts</a>, <a href="/alignment-lifts-pakistan" class="text-primary hover:underline">alignment lifts</a> and <a href="/bulletproof-car-lifts-pakistan" class="text-primary hover:underline">bulletproof vehicle lifts</a> with delivery, installation and on-site training across Pakistan.
        </p>
        <p class="text-xs text-on-surface-variant mt-3">Last updated: June 2026 by Autodiagnostix</p>
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Our Car Lift Range</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {lifts.length > 0 ? lifts.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={p.name} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" width="800" height="600" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">{p.brand || 'Workshop'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant">Browse our <a href="/products" class="text-primary underline">full product catalog</a> for the complete car lift range.</p>
          )}
        </div>
      </div>
    </section>



    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Which Car Lift Is Right for Your Workshop?</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-3">2-Post Lifts</h3>
          <p>Two-post lifts are the workhorse of Pakistani workshops. With capacities from 3.5 to 6.8 tons, they handle everything from sedans to SUVs and light commercial vehicles. The <strong>Liberty TPF-15C</strong> is a 6.8-ton clear-floor two-post lift designed for heavy vehicles. UNITE 2-post lifts are the value pick for new workshops.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-3">4-Post Lifts</h3>
          <p>Four-post lifts provide the maximum stability for wheel alignment, inspection bays and storage. The <strong>UNITE PL-FS40</strong> is a four-post lift with runways, ideal for wheel-alignment and long-wheelbase vehicles.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-3">Scissor Lifts</h3>
          <p>Scissor lifts are space-saving and ideal for low-ceiling workshops, tyre shops and quick-service bays. We supply the <strong>UNITE U-Z30C</strong> mobile mid-rise scissor lift, the <strong>Liberty FR-6105</strong> 3.5-ton scissor lift, and the <strong>Liberty FR-6108</strong> 4.2/5.0-ton wheel-alignment scissor lift with integrated alignment turnplates.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-3">Bulletproof &amp; Heavy-Duty Lifts</h3>
          <p>For armoured vehicles, cash-transit vans, and military/security fleets, we supply heavy-duty lifts with capacities of 6 tons and above. These lifts have reinforced columns, longer arms and higher lifting heights to accommodate armoured SUVs.</p>
          <h3 class="text-xl font-bold text-on-surface mt-8 mb-3">Jacks, Stands &amp; Workshop Accessories</h3>
          <p>We also supply the Launch 3-ton and 6-ton jack stands, the LH-330 / LH-340 dual-pump floor jacks, and the Launch TLT440W scissor jack , all workshop essentials.</p>
        </div>
      </div>
    </section>

    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-10">Pakistan-wide Delivery</h2>
        <p class="text-on-surface-variant leading-relaxed">We deliver car lifts, scissor lifts and 4-post lifts to every city in Pakistan. Installation guidelines are provided with every order, and our team is available to support workshops from delivery to warranty service.</p>
      </div>
    </section>


    <!-- SPECS / COMPARISON TABLE (GEO) -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-4 text-on-surface">Car Lift Comparison</h2>
        <p class="text-on-surface-variant leading-relaxed mb-6">Compare our car lift types at a glance:</p>
        <div class="overflow-x-auto bg-surface-container-lowest border border-outline-variant/20 rounded-xl">
          <table class="w-full text-sm">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Lift Type</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Capacity</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Best For</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Ceiling Height</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-outline-variant/20 bg-surface-container-low">
                <td class="px-4 py-3 text-on-surface">2-Post Lift</td>
                <td class="px-4 py-3 text-on-surface">3.5 to 6.8 ton</td>
                <td class="px-4 py-3 text-on-surface">General workshop, SUVs, armoured vehicles</td>
                <td class="px-4 py-3 text-on-surface">3.6 m minimum</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">4-Post Lift</td>
                <td class="px-4 py-3 text-on-surface">4 to 6 ton</td>
                <td class="px-4 py-3 text-on-surface">Wheel alignment, storage, inspection</td>
                <td class="px-4 py-3 text-on-surface">3.0 m minimum</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">Scissor Lift</td>
                <td class="px-4 py-3 text-on-surface">3.5 to 5 ton</td>
                <td class="px-4 py-3 text-on-surface">Tyre shops, low-ceiling workshops</td>
                <td class="px-4 py-3 text-on-surface">2.4 m minimum</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">Bulletproof Lift</td>
                <td class="px-4 py-3 text-on-surface">6 to 8 ton</td>
                <td class="px-4 py-3 text-on-surface">Armoured SUVs, cash-transit vans</td>
                <td class="px-4 py-3 text-on-surface">4.0 m minimum</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Car Lifts in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Request a Car Lift Quote</h2>
        <p class="mb-8 text-white/80">Tell us your workshop layout and capacity requirements , our team will spec the right lift with delivery &amp; installation included.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
