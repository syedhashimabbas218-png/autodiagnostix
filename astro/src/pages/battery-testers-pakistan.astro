---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const batteries = allProducts.filter(p => /bst-?560|bst-?860|battery|plug tester|spark plug|spt360/i.test(p.name + ' ' + p.summary));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Battery Testers in Pakistan', url: 'https://autodiagnostix.com.pk/battery-testers-pakistan' },
];

const faqs = [
  { question: 'Which battery tester is best for workshops in Pakistan?', answer: 'The Smartsafe BST-560 and BST-860 are the most popular battery testers in Pakistan , they test 12V and 24V batteries, alternators, and starters in seconds. For spark plug testing, the AUTOOL SPT360 is the preferred tool.' },
  { question: 'Can a battery tester diagnose the alternator and starter?', answer: 'Yes , the BST-560 and BST-860 battery testers from Smartsafe perform full system tests: battery state-of-health, alternator output voltage, and starter current draw. They print results and store customer records.' },
];
---

<BaseLayout
  title="Buy Battery Testers in Pakistan | Smartsafe BST-560/860"
  description="Buy battery testers in Pakistan from Autodiagnostix. Smartsafe BST-560 &amp; BST-860 12V/24V testers, AUTOOL SPT360 plug tester. Dealer prices. Delivery across Pakistan including Karachi, Lahore &amp; Islamabad."
  canonical="https://autodiagnostix.com.pk/battery-testers-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: 'Battery Testers in Pakistan: Smartsafe BST-560/860',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for Battery Testers in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/battery-testers-pakistan',
      keywords: ['battery testers Pakistan', 'Smartsafe BST-560', '12V battery tester Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/battery-testers-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        'Battery Testers',
        'Battery testers are handheld diagnostic instruments that assess the state-of-health, state-of-charge, and cranking performance of 12V and 24V automotive batteries using conductance testing technology. Professional models like the Smartsafe BST-560 and BST-860 also test alternator output and starter current draw, storing customer records for warranty traceability. Autodiagnostix supplies Smartsafe battery testers and AUTOOL plug testers across Pakistan.',
        'https://autodiagnostix.com.pk/battery-testers-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">Battery Testers</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          Battery Testers in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>battery testers in Pakistan</strong>. We supply the Smartsafe <a href="/product/bst-560-bst-860-battery-tester" class="text-primary hover:underline">BST-560 and BST-860</a> 12V/24V battery testers, plus the AUTOOL <a href="/product/autool-spt360-spark-plug-tester-tool" class="text-primary hover:underline">SPT360 plug tester</a> and spark plug tester. Essential workshop tools for battery, alternator, and starter diagnosis.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">Battery & Plug Testers</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {batteries.length > 0 ? batteries.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , battery tester in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">Battery Tester · {p.brand || 'Smartsafe'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse <a href="/brand/smartsafe" class="text-primary underline">all Smartsafe products</a>.</p>
          )}
        </div>
      </div>
    </section>



    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Workshop Battery Diagnostics</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <p>A reliable <strong>battery tester</strong> is essential for every workshop, tyre shop, and service center. The Smartsafe BST-560 and BST-860 perform full electrical-system tests in under 10 seconds , battery state-of-health, alternator ripple, starter draw, and earth-leakage , and store customer records for warranty and service history.</p>
          <p class="mt-4">For plug testing, the AUTOOL SPT360 spark plug tester is the workshop favourite , testing ignition, spark intensity, and fouling without removing the plug.</p>
        </div>
      </div>
    </section>

    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About Battery Testers in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="grid-answer"><div>
                <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
              </div></div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      .grid-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }
      details[open] .grid-answer {
        grid-template-rows: 1fr;
      }
      .grid-answer > div {
        overflow: hidden;
      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a Battery Tester Quote</h2>
        <p class="mb-8 text-white/80">Tell us your workshop's testing volume , we'll recommend the right battery tester.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
