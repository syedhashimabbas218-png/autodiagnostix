---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getProducts, sortByAvailability } from '../lib/strapi';
import { breadcrumbListSchema, faqSchema, organizationSchema, localBusinessSchema, articleSchema, speakableSchema, definitionBlock } from '../utils/schema';

export const prerender = false;

const allProducts = sortByAvailability(await getProducts());
const aligners = allProducts.filter(p => /align|aligner|x861|wa613|u-va2023|va2023/i.test(p.name));

const breadcrumbs = [
  { name: 'Home', url: 'https://autodiagnostix.com.pk/' },
  { name: 'Wheel Alignment in Pakistan', url: 'https://autodiagnostix.com.pk/wheel-alignment-in-pakistan' },
];

const faqs = [
  { question: 'Which 3D wheel aligner is best for a Pakistani workshop?', answer: 'The Launch X861 PRO is the most popular 3D wheel aligner in Pakistan , wireless, fast, and compatible with modern ADAS-equipped vehicles. The X861 LITE is the value pick for budget-conscious workshops. The UNITE U-VA2023 is a heavy-duty option for high-volume alignment bays.' },
  { question: 'What is the price of a 3D wheel alignment machine in Pakistan?', answer: 'A professional 3D wheel aligner in Pakistan costs between PKR 800,000 and PKR 2,500,000 depending on features (wireless vs wired, ADAS compatibility, sensor count). We supply Launch and UNITE aligners with installation, training, and after-sales support.' },
  { question: 'Do you install wheel aligners across Pakistan?', answer: 'Yes , we install and calibrate 3D wheel aligners nationwide, including Karachi, Lahore, Islamabad, Rawalpindi, Faisalabad, Multan, Peshawar, Sahiwal and other cities. We also provide on-site training for technicians.' },
];
---

<BaseLayout
  title="Buy 3D Wheel Alignment in Pakistan | Launch X861"
  description="Buy 3D wheel alignment machines in Pakistan from Autodiagnostix. Launch X861 PRO, X861 LITE, WA613, UNITE U-VA2023. Prices PKR 800,000–2,500,000. Installation &amp; training Karachi, Lahore, Islamabad &amp; all Pakistan."
  canonical="https://autodiagnostix.com.pk/wheel-alignment-in-pakistan"
  jsonLd={[breadcrumbListSchema(breadcrumbs), organizationSchema(), faqSchema(faqs), localBusinessSchema(),       articleSchema({
      headline: '3D Wheel Alignment in Pakistan: Launch X861 & WA613',
      description: 'Autodiagnostix is Pakistan\'s authorized dealer for 3D Wheel Alignment in Pakistan. Buy genuine products with delivery and installation guidelines across Pakistan.',
      url: 'https://autodiagnostix.com.pk/wheel-alignment-in-pakistan',
      keywords: ['3D wheel alignment Pakistan', 'Launch X861 PRO Pakistan', 'wheel alignment machine Pakistan'],
    }), speakableSchema('https://autodiagnostix.com.pk/wheel-alignment-in-pakistan', ['h1', '.geo-answer']),
      definitionBlock(
        '3D Wheel Alignment',
        '3D wheel alignment is a computerized vehicle alignment technology that uses high-resolution cameras and reflective targets to measure wheel angles (toe, camber, caster, SAI) in real time. Unlike traditional 2D systems, 3D aligners from Launch (X861 PRO, X861 LITE, WA613) and UNITE (U-VA2023) deliver faster, more accurate readings and are essential for modern ADAS-equipped vehicles sold in Pakistan.',
        'https://autodiagnostix.com.pk/wheel-alignment-in-pakistan'
      ),
    ]}
>
  <Header ctaLabel="Request a Quote" ctaHref="/contact" />

  <main class="min-h-screen pt-16">
    <section class="bg-surface pt-20 pb-12 px-8 border-b border-outline-variant/10">
      <div class="max-w-7xl mx-auto">
        <nav class="flex items-center gap-2 text-xs font-label uppercase tracking-widest text-on-surface-variant mb-6">
          <a href="/" class="hover:text-primary transition-colors">Home</a>
          <span class="text-[10px]">/</span>
          <span class="text-primary font-bold">3D Wheel Alignment</span>
        </nav>
        <h1 class="font-headline text-4xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.08]">
          3D Wheel Alignment in Pakistan
        </h1>
        <p class="text-on-surface-variant text-lg md:text-xl leading-relaxed max-w-4xl">
          Authorized dealer for <strong>3D wheel alignment machines in Pakistan</strong>. We supply the Launch <a href="/product/x861-pro-wheel-alignment-machine" class="text-primary hover:underline">X861 PRO</a>, <a href="/product/x861-lite-wheelalignment-machine" class="text-primary hover:underline">X861 LITE</a>, <a href="/product/wa613-wireless-3d-wheel-aligner" class="text-primary hover:underline">WA613 wireless 3D aligner</a>, and the <a href="/product/u-va2023" class="text-primary hover:underline">UNITE U-VA2023</a>. With delivery, installation, calibration and on-site training across Pakistan.
</section>

    <section class="py-16 px-8 bg-surface-container-low">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl font-headline font-extrabold tracking-tighter mb-10">3D Wheel Aligner Models</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {aligners.length > 0 ? aligners.map(p => (
            <a href={`/product/${p.id}`} class="group bg-white rounded-2xl overflow-hidden hover:shadow-2xl transition-all hover:-translate-y-1 flex flex-col border border-zinc-100">
              <div class="aspect-[4/3] bg-white p-6 flex items-center justify-center">
                {p.heroImages[0] ? (
                  <img src={p.heroImages[0]} alt={`${p.name} , 3D wheel alignment machine in Pakistan`} class="w-full h-full object-contain group-hover:scale-105 transition-transform" loading="lazy" />
                ) : (
                  <div class="text-zinc-300">No image</div>
                )}
              </div>
              <div class="p-6 flex flex-col flex-grow">
                <p class="text-[10px] font-bold uppercase tracking-widest text-primary mb-1">3D Wheel Aligner · {p.brand || 'Launch'}</p>
                <h3 class="font-headline text-lg font-bold tracking-tight mb-2 group-hover:text-primary transition-colors leading-snug">{p.name}</h3>
                <p class="text-on-surface-variant text-xs leading-relaxed mb-4 flex-grow line-clamp-3">{p.summary}</p>
                <span class="text-primary font-bold text-sm">View Specs →</span>
              </div>
            </a>
          )) : (
            <p class="text-on-surface-variant col-span-3">Browse our <a href="/products" class="text-primary underline">product catalog</a>.</p>
          )}
        </div>
      </div>
    </section>



    <section class="py-20 px-8 bg-white">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Why 3D Wheel Alignment?</h2>
        <div class="prose prose-lg max-w-none text-on-surface-variant">
          <p><strong>3D wheel alignment</strong> uses cameras and targets to measure wheel angles in real time, delivering faster, more accurate readings than traditional 2D systems. Modern Pakistani vehicles , especially SUVs and ADAS-equipped cars , require 3D alignment for precise toe, camber, caster, and steering axis inclination (SAI) measurements.</p>
          <p class="mt-4">We supply <strong>Launch X861 PRO</strong> and <strong>X861 LITE</strong> 3D aligners as Pakistan's authorized dealer. The wireless WA613 and UNITE U-VA2023 offer fast setup and a clean workshop floor with no cables.</p>
        </div>
      </div>
    </section>


    <!-- SPECS / COMPARISON TABLE (GEO) -->
    <section class="py-20 px-8 bg-surface-container-low">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-4 text-on-surface">3D Wheel Aligner Comparison</h2>
        <p class="text-on-surface-variant leading-relaxed mb-6">Compare our 3D wheel aligners:</p>
        <div class="overflow-x-auto bg-surface-container-lowest border border-outline-variant/20 rounded-xl">
          <table class="w-full text-sm">
            <thead class="bg-primary text-white">
              <tr>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Aligner</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Type</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Best For</th>
                <th class="px-4 py-3 text-left font-headline font-bold text-xs uppercase tracking-widest">Calibration</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-outline-variant/20 bg-surface-container-low">
                <td class="px-4 py-3 text-on-surface">Launch X861 PRO</td>
                <td class="px-4 py-3 text-on-surface">3D wireless</td>
                <td class="px-4 py-3 text-on-surface">High-end workshops, ADAS-equipped vehicles</td>
                <td class="px-4 py-3 text-on-surface">12-month calibration cycle</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">Launch X861 LITE</td>
                <td class="px-4 py-3 text-on-surface">3D wired</td>
                <td class="px-4 py-3 text-on-surface">Mid-range workshops, general alignment</td>
                <td class="px-4 py-3 text-on-surface">12-month calibration cycle</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">Launch WA613</td>
                <td class="px-4 py-3 text-on-surface">3D wireless</td>
                <td class="px-4 py-3 text-on-surface">Mobile alignment, multi-bay shops</td>
                <td class="px-4 py-3 text-on-surface">12-month calibration cycle</td>
              </tr>
              <tr class="border-t border-outline-variant/20">
                <td class="px-4 py-3 text-on-surface">UNITE U-VA2023</td>
                <td class="px-4 py-3 text-on-surface">3D</td>
                <td class="px-4 py-3 text-on-surface">High-volume alignment, dealerships</td>
                <td class="px-4 py-3 text-on-surface">12-month calibration cycle</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
    <!-- FAQ SECTION -->
    <section class="py-20 px-8 bg-white">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter mb-8">Frequently Asked Questions About 3D Wheel Alignment in Pakistan</h2>
        <div class="space-y-0 border-t border-zinc-200" data-accordion>
          {faqs.map((faq, i) => (
            <details class="group border-b border-zinc-200">
              <summary class="flex items-center justify-between py-5 cursor-pointer text-on-surface font-headline font-bold text-base md:text-lg leading-snug hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span class="pr-8">{faq.question}</span>
                <svg class="w-5 h-5 shrink-0 text-zinc-400 group-open:rotate-180 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </summary>
              <div class="pb-6 text-on-surface-variant leading-relaxed text-sm md:text-base geo-answer">{faq.answer}</div>
            </details>
          ))}
        </div>
      </div>
    <script>
      (() => {
        const group = document.querySelector('[data-accordion]');
        if (!group) return;
        const details = group.querySelectorAll('details');
        details.forEach(d => {
          const s = d.querySelector('summary');
          if (!s) return;
          s.addEventListener('click', (e) => {
            e.preventDefault();
            details.forEach(el => { if (el !== d) el.open = false; });
            d.open = !d.open;
          });
        });
      })();
</script>

    <style>

      details[open] .geo-answer,

      details[open] > p:last-of-type {

        animation: faqFadeIn 0.2s ease-out;

      }

      @keyframes faqFadeIn {

        from { opacity: 0; transform: translateY(-6px); }

        to { opacity: 1; transform: translateY(0); }

      }

    </style>
    </section>

    <section class="py-20 px-8 bg-primary text-white text-center">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-headline font-extrabold mb-6">Get a 3D Wheel Aligner Quote</h2>
        <p class="mb-8 text-white/80">Tell us your alignment bay size and vehicle mix , we'll recommend the right 3D aligner with installation and training.</p>
        <a href="/contact" class="inline-block bg-white text-primary font-bold px-10 py-4 uppercase tracking-widest text-sm hover:bg-zinc-100 transition-colors">Request a Quote</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
