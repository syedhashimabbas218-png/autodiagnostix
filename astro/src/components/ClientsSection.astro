---
interface Client {
  name: string;
  logo: string;
  url: string;
  /*
   * keepFilter:
   *   - 'revert'  : default state has the darken filter applied,
   *                 on hover the filter is removed (default)
   *   - 'always'  : the darken filter is applied in BOTH default
   *                 and hover states. Use this for logos that
   *                 have backgrounds/colors that would become
   *                 invisible on a light hover background.
   *   - 'never'   : the darken filter is NEVER applied. Use this
   *                 for logos that already have their own dark
   *                 fills (e.g. SVGs with whites already converted
   *                 to dark grey) so the invert filter doesn't
   *                 flip them back to invisible.
   */
  keepFilter: 'revert' | 'always' | 'never';
}

const clients: Client[] = [
  { name: 'Toyota Walton Motors', logo: '/images/clients/toyota-walton.webp', url: 'https://www.toyotawalton.com/', keepFilter: 'always' },
  { name: 'Honda Ring Road', logo: '/images/clients/honda-ringroad.webp', url: 'https://www.hondaringroad.pk/', keepFilter: 'revert' },
  { name: 'GWM Pakistan', logo: '/images/clients/gwm.webp', url: 'https://www.gwm-pakistan.com/', keepFilter: 'always' },
  { name: 'Changan Pakistan', logo: '/images/clients/changan.webp', url: 'https://changan.com.pk/', keepFilter: 'revert' },
  { name: 'Jetour Pakistan', logo: '/images/clients/jetour.webp', url: 'https://jetour.com.pk/', keepFilter: 'always' },
  { name: 'UNMOGIP', logo: '/images/clients/unmogip.webp', url: 'https://unmogip.unmissions.org/en', keepFilter: 'revert' },
  { name: 'Asif Traders', logo: '/images/clients/asif-traders.webp', url: 'https://asiftraders.org/', keepFilter: 'revert' },
  { name: 'KIA Lucky Motor Corp', logo: '/images/clients/kia.webp', url: 'https://kia-luckymotorcorp.com/', keepFilter: 'revert' },
  { name: 'Suzuki Pakistan', logo: '/images/clients/suzuki.svg', url: 'https://suzukipakistan.com/', keepFilter: 'revert' },
  { name: 'JAC Motors', logo: '/images/clients/jac.webp', url: 'https://jacen.jac.com.cn/', keepFilter: 'always' },
  { name: 'BMW Pakistan', logo: '/images/clients/bmw.webp', url: 'https://www.bmw-pakistan.com/', keepFilter: 'revert' },
  { name: 'PakWheels', logo: '/images/clients/pakwheels.webp', url: 'https://www.pakwheels.com/', keepFilter: 'revert' },
  { name: 'Pakistan Army', logo: '/images/clients/pakistan-army.webp', url: 'https://pakarmy.com.pk/', keepFilter: 'revert' },
  { name: 'Hyundai Nishat', logo: '/images/clients/hyundai-nishat.webp', url: 'https://hyundai-nishat.com/', keepFilter: 'revert' },
];
---

<section id="clients" class="py-20 md:py-24 bg-white border-t border-black/[0.06]">
  <div class="max-w-screen-2xl mx-auto px-8">
    <div class="flex flex-col items-center text-center mb-12 md:mb-16">
      <span class="text-[10px] font-bold uppercase tracking-[0.3em] text-primary mb-4">Trusted by Industry Leaders</span>
      <h2 class="text-3xl md:text-4xl font-headline font-extrabold tracking-tighter text-zinc-900 max-w-2xl">
        Our Clients
      </h2>
      <p class="mt-4 text-zinc-500 text-sm md:text-base max-w-2xl leading-relaxed">
        Authorized equipment partner for Pakistan's leading automotive manufacturers, dealerships, and institutions.
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-px bg-black/[0.06] border border-black/[0.06]">
      {clients.map((client) => (
        <a
          href={client.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={client.name}
          class="group relative bg-white aspect-[3/2] flex items-center justify-center p-6 md:p-8 transition-all duration-200 ease-out hover:bg-zinc-50 hover:z-10 hover:shadow-[0_0_0_1px_rgba(151,0,13,0.15)]"
        >
          <img
            src={client.logo}
            alt={client.name}
            class:list={[
              'max-h-12 md:max-h-14 w-auto max-w-full object-contain opacity-60 group-hover:opacity-100 transition-all duration-200 ease-out',
              'client-logo',
              client.keepFilter === 'always' ? 'client-logo--always' : '',
              client.keepFilter === 'never' ? 'client-logo--never' : '',
            ]}
            loading="lazy"
            referrerpolicy="no-referrer"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /*
   * Most logos start with a darken filter so any white/very-light
   * parts are converted to dark grey/black and stay visible on a
   * white card background. On hover, the filter is removed and the
   * logo reverts to its original colors.
   *
   *   --always : keep the darken filter across hover too. Use for
   *              logos whose original colors blend into a light
   *              hover background (Toyota, GWM, Jetour, JAC).
   *   --never  : never apply the darken filter. Use for logos that
   *              already have their own dark fills (PakWheels SVG
   *              with white->dark replacement) so the invert would
   *              flip them back to invisible.
   */
  #clients .client-logo {
    filter: invert(1) hue-rotate(180deg) saturate(0) brightness(0.85) contrast(1.1);
  }
  #clients a:hover .client-logo {
    filter: none;
  }
  #clients a:hover .client-logo--always {
    filter: invert(1) hue-rotate(180deg) saturate(0) brightness(0.85) contrast(1.1);
  }
  #clients .client-logo--never {
    filter: saturate(0.4) brightness(0.7);
  }
  #clients a:hover .client-logo--never {
    filter: saturate(0.4) brightness(0.7);
  }
</style>
