---
import homeData from '../data/homepage-content.json';
const footer = homeData.footer;

const currentYear = new Date().getFullYear();
const copyrightText = (footer?.bottom_bar?.copyright || '© {{year}} Autodiagnostix. All rights reserved.').replace('{{year}}', String(currentYear));

const socialIcons: Record<string, string> = {
  Facebook: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 0 1 1-1h3v-4h-3a5 5 0 0 0-5 5v2.01h-2l-.396 3.98h2.396v8.01Z"/></svg>',
  LinkedIn: '<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 5a2 2 0 1 1-4-.002 2 2 0 0 1 4 .002zM7 8.48H3V21h4V8.48zm6.32 0H9.34V21h3.94v-6.57c0-3.66 4.77-4 4.77 0V21H22v-7.93c0-6.17-7.06-5.94-8.72-2.91l.02-1.68z"/></svg>',
  Instagram: '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
};
---

<footer class="bg-zinc-50 border-t border-zinc-200">
  <div class="grid grid-cols-2 md:grid-cols-4 gap-12 w-full px-8 py-16 max-w-[1536px] mx-auto">
    <div class="col-span-2 md:col-span-1">
      <div class="mb-6 h-16 flex items-center">
        <img src="/logo-full.png" alt={footer?.company_info?.name || 'Autodiagnostix'} class="h-full w-auto object-contain" />
      </div>
      <p class="text-zinc-500 text-xs leading-relaxed max-w-xs mb-8">
        {footer?.company_info?.description || 'Your trusted partner for professional automotive diagnostic equipment in Pakistan.'}
      </p>
      <div class="flex gap-4">
        {(footer?.company_info?.social_icons || []).map(icon => (
          <a
            href={icon.href || '#'}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={icon.name}
            class="text-zinc-400 hover:text-primary cursor-pointer flex items-center justify-center w-5 h-5"
          >
            <span set:html={socialIcons[icon.name] || ''}></span>
          </a>
        ))}
      </div>
    </div>

    {(footer?.menu_columns || []).map(col => (
      <div>
        <span class="uppercase text-xs font-bold tracking-widest text-zinc-500 block mb-6">{col.title}</span>
        <ul class="space-y-4">
          {(col.links || []).map(link => (
            <li>
              <a
                href={link.href || '#'}
                class="text-sm text-zinc-500 hover:text-primary transition-all hover:translate-x-1 inline-block no-underline"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    {/* Newsletter hidden per request */}
  </div>

  <div class="w-full px-8 py-8 border-t border-zinc-200 max-w-[1536px] mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
    <span class="text-zinc-400 text-[10px] uppercase tracking-widest">{copyrightText}</span>
    <div class="flex gap-8">
      {(footer?.bottom_bar?.social_links || []).map(link => (
        <a
          href={link.href || '#'}
          target="_blank"
          rel="noopener noreferrer"
          class="text-zinc-400 text-[10px] uppercase tracking-widest hover:text-zinc-900 transition-colors no-underline"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>

