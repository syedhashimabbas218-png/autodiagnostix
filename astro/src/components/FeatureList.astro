---
interface Item {
  title: string;
  description: string;
  image?: string;
}

interface Props {
  eyebrow: string;
  title: string;
  headingId: string;
  items: Item[];
  compact?: boolean;
}

const { eyebrow, title, headingId, items, compact = false } = Astro.props;
---

<section class={`bg-surface ${compact ? 'py-10 md:py-12 lg:py-16 lg:pl-10 xl:pl-14' : 'py-12 md:py-16'}`} aria-labelledby={headingId}>
  <div class={`${compact ? '' : 'max-w-7xl mx-auto'} px-8`}>
    <header class={`${compact ? 'mb-6 md:mb-8' : 'mb-8 md:mb-12'} max-w-2xl`}>
      <span class="inline-flex items-center gap-2 text-[10px] font-bold tracking-[0.3em] uppercase text-primary mb-4">
        <span class="block w-8 h-px bg-primary" aria-hidden="true"></span>
        {eyebrow}
      </span>
      <h2 id={headingId} class={`${compact ? 'text-2xl md:text-3xl' : 'text-3xl md:text-4xl'} font-headline font-extrabold tracking-tighter text-on-surface leading-[1.05]`}>
        {title}
      </h2>
    </header>
    <ul class={`grid grid-cols-1 ${compact ? 'md:grid-cols-1' : 'md:grid-cols-2'} gap-x-12 ${compact ? 'gap-y-5' : 'gap-y-8'}`}>
      {items.map((feat, i) => {
        const text = feat.description || feat.title;
        return (
          <li class="group relative flex items-start gap-4 pl-1">
            <span
              class="shrink-0 mt-0.5 inline-flex items-center justify-center min-w-8 h-8 px-2 rounded-md bg-primary-container/10 text-primary text-[13px] font-bold font-headline tabular-nums"
              aria-hidden="true"
            >
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="flex-1 text-[14px] leading-relaxed text-slate-700 pt-1">
              {text}
            </span>
          </li>
        );
      })}
    </ul>
  </div>
</section>
