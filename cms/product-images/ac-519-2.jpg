<script>
    $('.buyLocal-more').click(function(){
        var id=$('.buyLocal-menu').data('id');
        window.location.href="/mess/id/"+id;
    })
    
    
    
    $(document).on('click','.buyLocal-drop li',function(){
        $(this).parent().slideUp(300).prev().find('input').val($(this).text());
        $(this).parent().prev().attr('data-id',$(this).attr('data-id'));
        id=$('.buyLocal-menu').attr('data-id');
        data=Ajax("/ajax/hezuo",{id:id});
    })

    $('#country').keyup(function(){
        var keyword=$(this).val();
        
        $.ajax({
             type: "POST",
             url: "/ajax/country",
             data:{'scode':46,'keyword':keyword},
             dataType: "json",
             success: function(data) { 
                 $("#countryList").html('');
                 $('#countryList').html(data.data);
             }
        });
    })
</script>
                        
                        
