    <script src="/apps/admin/view/default/layui/layui.all.js"></script>

    <script src="/template/default/js/form2.js?v=20240301113717"></script>

    <script src="/template/default/swiper/swiper.min.js?v=20221201152028"></script>
    <script src="/template/default/js/threesixty.min.js?v=20230215160832"></script>
    <script type="text/javascript">
        $(function () {
            // 360度
            if ($(".proxqpar-rotate").hasClass("onshow")) { window.onload = rotateFn; }
            var screenWdh = "100%", screenHgt = "100%";
            var filePath = $(".proxqpar-rotate").attr("filePath");
            var picNum = $(".proxqpar-rotate").attr("picNum");
            var picSuffix = $(".proxqpar-rotate").attr("picSuffix");
            var imgAlt = $(".proxqpar-rotate").attr("imgAlt");
            function rotateFn() {
                product = $('.threesixty').ThreeSixty({
                    totalFrames: picNum,
                    endFrame: picNum / 2, currentFrame: 1,
                    imgList: '.threesixty_images', progress: '.proxqpar-spinner',
                    imagePath: filePath, ext: '.' + picSuffix,
                    height: screenHgt, width: screenWdh,
                    alt:imgAlt,
                    navigation: false, disableSpin: true
                });
                $(".proxqpar-rotate-btn").click(function(){console.log(1); $(this).fadeOut(300)});
                // product.play();
                // $(".threesixty").hover(function () {product.stop();}, function () {product.play();});
            }

            // 产品详情导航

            color();
            function color() {
                var boxTop = []
                var navH = $('.Header').height() + $('.detNav').height();
                $('.boxCon').each(function (i) {
                    boxTop.push($(this).offset().top);
                });
                $('.detNav a').click(function () {
                    $('html,body').animate({ scrollTop: boxTop[$(this).index()] - navH }, 800);
                });
                if ($(window).scrollTop() > $('.detBan').height() + $('.Header').height()) {
                    $('.detNav').addClass('scroll');
                } else {
                    $('.detNav').removeClass('scroll');

                }
                $(window).scroll(function () {
                    if ($(window).scrollTop() > $('.detBan').height() + $('.Header').height()) {
                        $('.detNav').addClass('scroll');
                    } else {
                        $('.detNav').removeClass('scroll');

                    }
                    for (var i = 0; i < boxTop.length; i++) {
                        if ($(window).scrollTop() > boxTop[i] - $(window).height() / 5) {
                            $('.detNav a').eq(i).addClass('active').siblings().removeClass('active');
                        } else {
                            return false;
                        }
                    }
                });
            }





            if ($('.detPar-img img').length == null || $('.detPar-img img').length==0) {
                $('.detPar-con').addClass('imgNull');
            }
            // 视频
            $('.detVideo-btn').click(function () {
                $(this).parent().hide();
                $('.detVideo video').attr({ 'autoplay': 'autoplay', 'controls': 'controls' });
                $('.detVideo video')[0].play();
            })
            $('.detVideo video').bind('ended', function () {
                $('.detVideo-img').show();
                $('.detVideo video')[0].pause();
                $('.detVideo video').removeAttr('autoplay');
                $('.detVideo video').removeAttr('controls');
                $('.detVideo video')[0].currentTime = 0;
            });

            // Features
            var FeaSwiper = new Swiper('.detFea-swp .swiper-container', {
                speed: 1000,
                pagination: { el: '.detFea-pagination', clickable: true, },
            });
            // What
            var FeaSwiper = new Swiper('.detWhat-img .swiper-container', {
                speed: 1000,
                pagination: { el: '.detWhat-pagination', clickable: true, },
            });
            // 下拉
            $('.buyLocal-menu input').focus(function(){
                $(this).attr('placeholder','');
                $(this).attr('placeholder','');
                $('.buyLocal-drop').stop().slideDown(300);
            }).blur(function(){
                setTimeout(()=>{
                    $(this).attr('placeholder','country');
                },300)
                setTimeout(()=>{
                    $('.buyLocal-drop').stop().slideUp(300);
                },100)

            })
            $('.buyLocal-drop li').click(function () {
                $(this).parent().slideUp(300).prev().find('input').val($(this).text());
                $(this).parent().prev().attr('data-id', $(this).attr('data-id'));
            });

            var listSwiper = new Swiper('.proXL-list-swp .swiper-container', {
                speed: 1000,
                pagination: { el: '.proXL-list-pagination', clickable: true, },
            });
        });
        $(".detBan-text,.detVideo-header .pagesTitle").addClass("wow fadeInLeft").attr("data-wow-delay", '0.3s');
        $(".detBan-img,.detVideo-text").addClass("wow fadeInRight").attr("data-wow-delay", '0.3s');
        $(".detVideo-con").addClass("wow zoomIn").attr("data-wow-delay", '0.5s');
        $(".pagesTitle,.detFun-header,.details .contMsg .contain").addClass("wow fadeInUp").attr("data-wow-delay", '0.3s');
        $(".detFea-con,.detFun-table,.detWhat-con,.detPar-con,.detMain-con,.detMain-down").addClass("wow fadeInUp").attr("data-wow-delay", '0.5s');
        var delayBan = 0.5;
        $('.newsList-con li').each(function () {
            delayBan = delayBan * ($(this).index() + 1);
            $(this).addClass('wow fadeInUp').attr({
                'data-wow-delay': delayBan + 's',
                'data-wow-duration': '1s'
            });
            delayBan = 0.3
        })
        delayBan = 0.5; $('.proXL-list-item').each(function (i) { delayBan = delayBan * ((i % 2) + 1); $(this).addClass('wow fadeInUp').attr({ 'data-wow-delay': delayBan + 's', 'data-wow-duration': '.8s' }); delayBan = 0.3; });
        wow = new WOW({
            boxClass: 'wow',
            animateClass: 'animated',
            offset: 0,
            mobile: true,
            live: true
        });
        wow.init();
    </script>

    <script src="/apps/admin/view/default/layui/layui.all.js"></script>
    <script>
        $('.detBan-more').click(function(){
            $('.proDet-popup-box').show();
            $('body,html').css("overflow","hidden")
        });
        $('.proDet-popup-close').click(function(){
            $('.proDet-popup-box').hide();
            $('body,html').css("overflow","")            
        });
        $('.proDet-popup-box').click(function (event) {
            var _con = $('.proDet-popup');
            if (!_con.is(event.target) && _con.has(event.target).length === 0) {
                $('.proDet-popup-box').hide();
            $('body,html').css("overflow","")   
            }
        });
        $('.form_message').click(function () {
            var name = $.trim($('input[name="name"]').val());
            var phone = $.trim($('input[name="phone"]').val());
            var email = $.trim($('input[name="email"]').val());
            var country = $.trim($('input[name="country"]').val());
            var whatsapp = $.trim($('input[name="whatsapp"]').val());

            var content = $.trim($('input[name="content"]').val());
            var checkcode = $.trim($('input[name="checkcode"]').val());
            
            var currentUrl = window.location.href;
            
            $.ajax({
                type: "POST",
                url: "/message",
                dataType: "json",
                data: { name: name, phone: phone, email: email, country: country,content: content, checkcode: checkcode,currentUrl:currentUrl,whatsapp:whatsapp},
                success: function (data) {
                    if (data.code) {
                        layer.msg(data.data, { icon: 6, time: 1200 });
                        setTimeout(function(){window.location.href="/success";},1200);
                    }
                    if (data.code == 0) {
                        layer.msg(data.data, { icon: 5, time: 1200 });

                    }

                }

            });

        });
        
        $('.form_pro2').click(function () {
            var name = $.trim($('input[name="name2"]').val());
            var phone = $.trim($('input[name="phone2"]').val());
            var email = $.trim($('input[name="email2"]').val());
            var country = $.trim($('input[name="country2"]').val());
            var whatsapp = $.trim($('input[name="whatsapp2"]').val());

            var content = $.trim($('textarea[name="content2"]').val());
            var checkcode = $.trim($('input[name="checkcode2"]').val());
            
            var currentUrl = window.location.href;
            
            $.ajax({
                type: "POST",
                url: "/message",
                dataType: "json",
                data: { name: name, phone: phone, email: email, country:country,content: content, checkcode: checkcode,currentUrl:currentUrl,whatsapp:whatsapp},
                success: function (data) {
                    if (data.code) {
                        layer.msg(data.data, { icon: 6, time: 1200 });
                        setTimeout(function(){window.location.href="/success";},1200);
                    }
                    if (data.code == 0) {
                        layer.msg(data.data, { icon: 5, time: 1200 });

                    }

                }

            });

        });
    </script>
</body>

