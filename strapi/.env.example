# Server
HOST=0.0.0.0
PORT=1337

# Public URL (needed for admin panel to work behind Coolify proxy)
PUBLIC_URL=http://localhost:1337

# Database
DATABASE_CLIENT=postgres
# Connection string (mutually exclusive with discrete DATABASE_HOST/PORT/NAME/USERNAME/PASSWORD)
DATABASE_URL=postgres://autodiagnostix:password@localhost:5432/autodiagnostix_strapi
# Discrete database settings (used when DATABASE_URL is not set)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=autodiagnostix_strapi
DATABASE_USERNAME=autodiagnostix
DATABASE_PASSWORD=password
DATABASE_SSL=false

# Secrets — generate each with: openssl rand -base64 32
# Example: $ openssl rand -base64 32
APP_KEYS="key1,key2,key3,key4"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# CORS — comma-separated allowed origins (e.g. https://autodiagnostix.com,https://www.autodiagnostix.com)
CORS_ORIGINS=*
